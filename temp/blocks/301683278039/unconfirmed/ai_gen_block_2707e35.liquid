{% doc %}
  @prompt
    Adicione uma grade de produtos com titulo, subtitulo, seletor de qual coleção vai ser exibida na grade, seletor de quantidade de produtos por linha e botão ver mais para expandir a exibição para mais linhas., a exibição do card do produto esta diferente do restante do site. Preciso que fique no mesmo padrão.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-product-grid__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-product-grid__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-product-grid__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-product-grid__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: 32px;
  }

  @media screen and (max-width: 749px) {
    .ai-product-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_mobile }}, 1fr);
    }
  }

  .ai-product-grid__item-{{ ai_gen_id }} {
    display: none;
  }

  .ai-product-grid__item-{{ ai_gen_id }}.visible {
    display: block;
  }

  .ai-product-card-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    height: 100%;
  }

  .ai-product-card__inner-{{ ai_gen_id }} {
    background-color: transparent;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-product-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
    border-radius: 12px;
  }

  .ai-product-card__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-card__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-product-card__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-product-card__content-{{ ai_gen_id }} {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-product-card__title-{{ ai_gen_id }} {
    font-size: 14px;
    color: #201b14;
    margin: 0;
    font-weight: 400;
    line-height: 1.4;
  }

  .ai-product-card__price-{{ ai_gen_id }} {
    font-size: 16px;
    color: #201b14;
    font-weight: 600;
    margin: 0;
  }

  .ai-product-grid__footer-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-product-grid__button-{{ ai_gen_id }} {
    padding: 14px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-product-grid__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  .ai-product-grid__button-{{ ai_gen_id }}.hidden {
    display: none;
  }

  .ai-product-grid__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
    font-size: 16px;
  }
{% endstyle %}

<product-grid-{{ ai_gen_id }} class="ai-product-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.title != blank or block.settings.subtitle != blank %}
    <div class="ai-product-grid__header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-product-grid__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <p class="ai-product-grid__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>
  {% endif %}

  {% if block.settings.collection != blank %}
    {% assign collection = block.settings.collection %}
    {% assign products = collection.products %}
    {% assign initial_rows = block.settings.initial_rows %}
    {% assign products_per_row = block.settings.products_per_row %}
    {% assign initial_count = initial_rows | times: products_per_row %}

    {% if products.size > 0 %}
      <div class="ai-product-grid__grid-{{ ai_gen_id }}">
        {% for product in products %}
          <div class="ai-product-grid__item-{{ ai_gen_id }} {% if forloop.index <= initial_count %}visible{% endif %}" data-index="{{ forloop.index }}">
            <a href="{{ product.url }}" class="ai-product-card-{{ ai_gen_id }}">
              <div class="ai-product-card__inner-{{ ai_gen_id }}">
                <div class="ai-product-card__image-wrapper-{{ ai_gen_id }}">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 600 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      class="ai-product-card__image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="600"
                      height="600"
                    >
                  {% else %}
                    <div class="ai-product-card__image-placeholder-{{ ai_gen_id }}">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
                <div class="ai-product-card__content-{{ ai_gen_id }}">
                  <h3 class="ai-product-card__title-{{ ai_gen_id }}">{{ product.title }}</h3>
                  <div class="ai-product-card__price-{{ ai_gen_id }}">{{ product.price | money }}</div>
                </div>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>

      {% if products.size > initial_count %}
        <div class="ai-product-grid__footer-{{ ai_gen_id }}">
          <button class="ai-product-grid__button-{{ ai_gen_id }}" data-load-more>
            {{ block.settings.button_text }}
          </button>
        </div>
      {% endif %}
    {% else %}
      <div class="ai-product-grid__empty-{{ ai_gen_id }}">
        Nenhum produto encontrado nesta coleção.
      </div>
    {% endif %}
  {% else %}
    <div class="ai-product-grid__empty-{{ ai_gen_id }}">
      Selecione uma coleção para exibir os produtos.
    </div>
  {% endif %}
</product-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.loadMoreButton = this.querySelector('[data-load-more]');
        this.items = this.querySelectorAll('.ai-product-grid__item-{{ ai_gen_id }}');
        this.productsPerRow = {{ block.settings.products_per_row }};
        this.currentVisibleCount = {{ block.settings.initial_rows | times: block.settings.products_per_row }};
      }

      connectedCallback() {
        if (this.loadMoreButton) {
          this.loadMoreButton.addEventListener('click', () => this.loadMore());
        }
      }

      loadMore() {
        const nextCount = this.currentVisibleCount + this.productsPerRow;
        
        for (let i = this.currentVisibleCount; i < nextCount && i < this.items.length; i++) {
          this.items[i].classList.add('visible');
        }
        
        this.currentVisibleCount = nextCount;
        
        if (this.currentVisibleCount >= this.items.length) {
          this.loadMoreButton.classList.add('hidden');
        }
      }
    }

    customElements.define('product-grid-{{ ai_gen_id }}', ProductGrid{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Grade de produtos",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Conteúdo"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Título",
      "default": "Nossos produtos"
    },
    {
      "type": "inline_richtext",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Descubra nossa seleção especial"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Coleção"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "products_per_row",
      "label": "Produtos por linha (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "products_per_row_mobile",
      "label": "Produtos por linha (mobile)",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "initial_rows",
      "label": "Linhas iniciais visíveis",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Espaçamento entre produtos",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Largura no desktop",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Botão ver mais"
    },
    {
      "type": "inline_richtext",
      "id": "button_text",
      "label": "Texto do botão",
      "default": "Ver mais produtos"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Cor de fundo",
      "default": "#5a4742"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Cor de fundo (hover)",
      "default": "#735e59"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Cor do texto",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Arredondamento do botão",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "header",
      "content": "Estilo dos títulos"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Tamanho do título",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Cor do título",
      "default": "#201b14"
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Tamanho do subtítulo",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Cor do subtítulo",
      "default": "#4f4442"
    }
  ],
  "presets": [
    {
      "name": "Grade de produtos"
    }
  ]
}
{% endschema %}
