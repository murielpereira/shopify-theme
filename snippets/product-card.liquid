{% comment %}
  Reutilizável — card de produto
  Parâmetros esperados (via assign antes do render):
    card_product   — objeto product obrigatório
    card_show_badge — boolean (opcional)
{% endcomment %}

{%- liquid
  assign card_url   = card_product.url
  assign card_title = card_product.title
  assign card_price = card_product.price | money
  assign card_img   = card_product.featured_image
  assign card_badge = ''
  if card_product.tags contains 'heritage'
    assign card_badge = 'Heritage'
  elsif card_product.tags contains 'novo'
    assign card_badge = 'Novo'
  elsif card_product.tags contains 'mais-vendido'
    assign card_badge = 'Mais Vendido'
  endif
-%}

<div class="ame-card" data-product-card>
  <a href="{{ card_url }}" class="ame-card__link" tabindex="-1" aria-hidden="true">
    <div class="ame-card__image-wrap">
      {%- if card_img != blank -%}
        {%- assign card_img_alt = card_img.alt | default: card_title | escape -%}
        {{
          card_img
          | image_url: width: 600
          | image_tag: loading: 'lazy', class: 'ame-card__img', alt: card_img_alt
        }}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'ame-card__img ame-card__img--placeholder' }}
      {%- endif -%}

      {%- if card_badge != '' -%}
        <span class="ame-chip ame-chip--primary ame-card__badge">{{ card_badge }}</span>
      {%- endif -%}

      <button
        class="ame-wishlist ame-card__wishlist"
        aria-label="Adicionar aos favoritos"
        data-wishlist-btn="{{ card_product.id }}"
        type="button"
        aria-pressed="false"
      >
        <span class="material-symbols-outlined" style="font-size:1.125rem; font-variation-settings:'FILL' 0;">favorite</span>
      </button>

      <!-- Quick add -->
      <div class="ame-card__quick-add">
        {%- form 'product', card_product, data-quick-form: '' -%}
          <input type="hidden" name="id" value="{{ card_product.selected_or_first_available_variant.id }}">
          <input type="hidden" name="quantity" value="1">
          <button type="submit" class="ame-card__quick-btn" {% unless card_product.available %}disabled{% endunless %}>
            {%- if card_product.available -%}
              Adicionar ao Carrinho
            {%- else -%}
              Esgotado
            {%- endif -%}
          </button>
        {%- endform -%}
      </div>
    </div>
  </a>

  <div class="ame-card__info">
    {%- if card_product.metafields.custom.collection_name != blank -%}
      <p class="ame-card__collection">{{ card_product.metafields.custom.collection_name }}</p>
    {%- elsif card_product.collections.first != blank -%}
      <p class="ame-card__collection">{{ card_product.collections.first.title }}</p>
    {%- endif -%}

    <h3 class="ame-card__title">
      <a href="{{ card_url }}">{{ card_title }}</a>
    </h3>

    <div class="ame-card__bottom">
      <p class="ame-card__price">
        {%- if card_product.compare_at_price > card_product.price -%}
          <s class="ame-card__price-compare">{{ card_product.compare_at_price | money }}</s>
        {%- endif -%}
        {{ card_price }}
      </p>

      <!-- Color swatches from variants -->
      {%- assign color_option = card_product.options_with_values | where: 'name', 'Color' | first -%}
      {%- if color_option == blank -%}
        {%- assign color_option = card_product.options_with_values | where: 'name', 'Cor' | first -%}
      {%- endif -%}
      {%- if color_option == blank -%}
        {%- assign color_option = card_product.options_with_values | where: 'name', 'Acabamento' | first -%}
      {%- endif -%}
      {%- if color_option -%}
        <div class="ame-card__swatches">
          {%- for value in color_option.values limit: 4 -%}
            <span
              class="ame-card__swatch"
              title="{{ value }}"
              style="background: {{ value | downcase | replace: ' ', '-' | prepend: 'var(--swatch-' | append: ', #ccc)' }}"
            ></span>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .ame-card { position: relative; }
  .ame-card__link { display: block; }

  .ame-card__image-wrap {
    position: relative;
    border-radius: var(--radius-lg, 0.5rem);
    overflow: hidden;
    aspect-ratio: 1 / 1;
    width: 100%;
    background: var(--color-surface-container-highest, #ece1d5);
    margin-bottom: 1rem;
  }

  .ame-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    mix-blend-mode: multiply;
    opacity: 0.9;
    transition: transform 1s var(--ease-luxury, cubic-bezier(0.22,1,0.36,1));
  }
  .ame-card__img--placeholder { opacity: 0.3; }
  .ame-card:hover .ame-card__img { transform: scale(1.05); }

  .ame-card__badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 2;
  }

  .ame-card__wishlist {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 2;
    background: rgba(255,255,255,0.65);
    backdrop-filter: blur(8px);
    border: none;
    cursor: pointer;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(90,71,66,0.4);
    transition: color 0.25s ease, transform 0.25s ease;
  }
  .ame-card__wishlist:hover,
  .ame-card__wishlist.is-active { color: var(--color-primary, #5a4742); transform: scale(1.15); }
  .ame-card__wishlist.is-active .material-symbols-outlined { font-variation-settings: 'FILL' 1; }

  .ame-card__quick-add {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    right: 1rem;
    z-index: 2;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.28s ease, transform 0.28s ease;
  }
  .ame-card:hover .ame-card__quick-add { opacity: 1; transform: translateY(0); }

  .ame-card__quick-btn {
    width: 100%;
    background: rgba(90,71,66,0.9);
    color: #ffffff;
    border: none;
    cursor: pointer;
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0.75rem;
    border-radius: var(--radius-md, 0.25rem);
    backdrop-filter: blur(4px);
    transition: background 0.2s ease;
  }
  .ame-card__quick-btn:hover { background: var(--color-primary, #5a4742); }
  .ame-card__quick-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  .ame-card__collection {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.625rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(90,71,66,0.5);
    margin-bottom: 0.375rem;
  }

  .ame-card__title {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 1.0625rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-on-background, #201b14);
    margin-bottom: 0.5rem;
  }
  .ame-card__title a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .ame-card:hover .ame-card__title a { color: var(--color-primary, #5a4742); }

  .ame-card__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .ame-card__price {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 1rem;
    color: var(--color-on-background, #201b14);
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .ame-card__price-compare {
    font-size: 0.75rem;
    color: rgba(90,71,66,0.5);
  }

  .ame-card__swatches { display: flex; gap: 0.375rem; }
  .ame-card__swatch {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 50%;
    border: 1px solid rgba(210,195,192,0.3);
  }
{% endstylesheet %}

<script>
  (() => {
    document.querySelectorAll('[data-wishlist-btn]').forEach(btn => {
      btn.addEventListener('click', () => {
        btn.classList.toggle('is-active');
        const isActive = btn.classList.contains('is-active');
        btn.setAttribute('aria-pressed', isActive);
        const icon = btn.querySelector('.material-symbols-outlined');
        icon.style.fontVariationSettings = isActive ? "'FILL' 1" : "'FILL' 0";
      });
    });

    document.querySelectorAll('[data-quick-form]').forEach(form => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = form.querySelector('[type="submit"]');
        const orig = btn.textContent;
        btn.textContent = 'Adicionando...';
        btn.disabled = true;
        btn.setAttribute('aria-busy', 'true');
        await fetch('/cart/add.js', { method: 'POST', body: new FormData(form) });
        btn.textContent = 'Adicionado ✓';
        btn.removeAttribute('aria-busy');
        setTimeout(() => { btn.textContent = orig; btn.disabled = false; }, 1800);
      });
    });
  })();
</script>
