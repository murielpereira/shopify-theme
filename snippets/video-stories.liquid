{% comment %}
  Âme — Video Stories widget
  Renderiza vídeos como stories (círculos), carrossel (cards 9:16) ou spotlight (cards 16:9).
  Modal em lightbox com player (YouTube, Vimeo ou vídeo nativo Shopify).

  Parâmetros (todos com defaults):
    videos          — array (de product.media filtrada OU de section.blocks)
    source_type     — 'media' | 'blocks'                    (default 'media')
    widget_id       — string única                          (default 'vs-default')
    format          — 'stories' | 'carrossel' | 'spotlight' (default 'stories')
    border_type     — 'solida' | 'degrade'                  (default 'solida')
    cor             — hex (1ª cor)                          (default '#5a4742')
    cor_fim         — hex (2ª cor, só degradê)              (default '#735e59')
    cor_3           — hex (3ª cor opcional, só degradê)     (default '')
    angulo          — int 0-360                             (default 135)
    tamanho         — int 50-180 px (largura do thumb)      (default 70)
    espessura       — int 1-10 px                           (default 3)
    espacamento     — int 4-40 px                           (default 12)
    mostrar_titulo  — boolean                               (default true)
    autoplay        — boolean (autoplay no modal)           (default true)
    cta_default     — string (texto padrão do CTA)          (default 'Ver mais')
{% endcomment %}

{%- liquid
  assign vs_videos = videos
  assign vs_source = source_type | default: 'media'
  assign vs_id = widget_id | default: 'vs-default'
  assign vs_format = format | default: 'stories'
  assign vs_btype = border_type | default: 'solida'
  assign vs_cor = cor | default: '#5a4742'
  assign vs_cor_fim = cor_fim | default: '#735e59'
  assign vs_cor_3 = cor_3 | default: ''
  assign vs_angulo = angulo | default: 135
  assign vs_tamanho = tamanho | default: 70
  assign vs_espessura = espessura | default: 3
  assign vs_espacamento = espacamento | default: 12
  assign vs_mostrar_titulo = mostrar_titulo
  if vs_mostrar_titulo == nil
    assign vs_mostrar_titulo = true
  endif
  assign vs_autoplay = autoplay
  if vs_autoplay == nil
    assign vs_autoplay = true
  endif
  assign vs_cta_default = cta_default | default: 'Ver mais'

  assign vs_has_videos = false
  if vs_videos.size > 0
    assign vs_has_videos = true
  endif

  if vs_btype == 'degrade'
    if vs_cor_3 != blank and vs_cor_3 != ''
      assign vs_ring_bg = 'linear-gradient(' | append: vs_angulo | append: 'deg, ' | append: vs_cor | append: ', ' | append: vs_cor_fim | append: ', ' | append: vs_cor_3 | append: ')'
    else
      assign vs_ring_bg = 'linear-gradient(' | append: vs_angulo | append: 'deg, ' | append: vs_cor | append: ', ' | append: vs_cor_fim | append: ')'
    endif
  else
    assign vs_ring_bg = vs_cor
  endif
-%}

{%- if vs_has_videos -%}
<div
  class="ame-vs ame-vs--{{ vs_format }}"
  data-vs-widget="{{ vs_id }}"
  style="
    --vs-ring-bg: {{ vs_ring_bg }};
    --vs-tamanho: {{ vs_tamanho }}px;
    --vs-espessura: {{ vs_espessura }}px;
    --vs-espacamento: {{ vs_espacamento }}px;
  "
>
  <div class="ame-vs__track" data-vs-track>
    {%- for v in vs_videos -%}
      {%- liquid
        assign vt_type = ''
        assign vt_id = ''
        assign vt_host = ''
        assign vt_title = ''
        assign vt_image = ''
        assign vt_native_src = ''
        assign vt_cta_url = ''
        assign vt_cta_label = ''

        if vs_source == 'media'
          if v.media_type == 'external_video'
            assign vt_type = 'external'
            assign vt_id = v.external_id
            assign vt_host = v.host
            assign vt_title = v.alt
            if v.preview_image != blank
              assign vt_image = v.preview_image | image_url: width: 480
            endif
          elsif v.media_type == 'video'
            assign vt_type = 'native'
            assign vt_id = v.id
            assign vt_title = v.alt
            if v.preview_image != blank
              assign vt_image = v.preview_image | image_url: width: 480
            endif
            if v.sources.size > 0
              assign vt_native_src = v.sources[0].url
              for s in v.sources
                if s.format == 'mp4' and s.height >= 720
                  assign vt_native_src = s.url
                  break
                endif
              endfor
            endif
          endif
        elsif vs_source == 'blocks'
          assign block_url_raw = v.settings.url | default: ''
          assign block_url = block_url_raw | downcase
          assign vt_title = v.settings.title
          if v.settings.image != blank
            assign vt_image = v.settings.image | image_url: width: 480
          endif
          assign vt_cta_url = v.settings.cta_url
          assign vt_cta_label = v.settings.cta_label | default: vs_cta_default

          if block_url contains 'youtube.com/watch'
            assign vt_type = 'external'
            assign vt_host = 'youtube'
            assign vt_id = block_url_raw | split: 'v=' | last | split: '&' | first
          elsif block_url contains 'youtu.be/'
            assign vt_type = 'external'
            assign vt_host = 'youtube'
            assign vt_id = block_url_raw | split: 'youtu.be/' | last | split: '?' | first
          elsif block_url contains 'youtube.com/shorts/'
            assign vt_type = 'external'
            assign vt_host = 'youtube'
            assign vt_id = block_url_raw | split: 'shorts/' | last | split: '?' | first
          elsif block_url contains 'vimeo.com/'
            assign vt_type = 'external'
            assign vt_host = 'vimeo'
            assign vt_id = block_url_raw | split: 'vimeo.com/' | last | split: '?' | first
          endif

          if vt_image == '' and vt_type == 'external' and vt_host == 'youtube' and vt_id != ''
            assign vt_image = 'https://img.youtube.com/vi/' | append: vt_id | append: '/hqdefault.jpg'
          endif
        endif
      -%}

      {%- if vt_id != '' or vt_native_src != '' -%}
        <button
          class="ame-vs__item"
          type="button"
          data-vs-open
          data-vs-type="{{ vt_type }}"
          data-vs-id="{{ vt_id }}"
          data-vs-host="{{ vt_host }}"
          data-vs-src="{{ vt_native_src | escape }}"
          data-vs-title="{{ vt_title | escape }}"
          data-vs-cta-url="{{ vt_cta_url | escape }}"
          data-vs-cta-label="{{ vt_cta_label | escape }}"
          aria-label="Reproduzir {{ vt_title | default: 'vídeo' | escape }}"
          {%- if v.shopify_attributes %} {{ v.shopify_attributes }}{% endif %}
        >
          <div class="ame-vs__ring">
            <div class="ame-vs__media">
              {%- if vt_image != '' -%}
                <img src="{{ vt_image }}" alt="{{ vt_title | escape }}" loading="lazy">
              {%- else -%}
                <span class="ame-vs__media-fallback" aria-hidden="true">
                  <span class="material-symbols-outlined">play_circle</span>
                </span>
              {%- endif -%}
              <span class="ame-vs__play" aria-hidden="true">
                <span class="material-symbols-outlined">play_arrow</span>
              </span>
            </div>
          </div>
          {%- if vs_mostrar_titulo and vt_title != blank -%}
            <span class="ame-vs__title">{{ vt_title }}</span>
          {%- endif -%}
        </button>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<style>
  .ame-vs {
    --vs-ring-bg: #5a4742;
    --vs-tamanho: 70px;
    --vs-espessura: 3px;
    --vs-espacamento: 12px;
    margin: 1.5rem 0;
  }
  .ame-vs__track {
    display: flex;
    gap: var(--vs-espacamento);
    overflow-x: auto;
    padding: 0.25rem 0.125rem 0.5rem;
    scrollbar-width: none;
    scroll-snap-type: x proximity;
  }
  .ame-vs__track::-webkit-scrollbar { display: none; }

  .ame-vs__item {
    flex-shrink: 0;
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    scroll-snap-align: start;
    transition: transform 0.3s var(--ease-luxury, cubic-bezier(0.22, 1, 0.36, 1));
  }
  .ame-vs__item:hover { transform: translateY(-2px); }
  .ame-vs__item:focus-visible {
    outline: 2px solid var(--color-primary, #5a4742);
    outline-offset: 4px;
    border-radius: 0.25rem;
  }

  .ame-vs__ring {
    position: relative;
    display: inline-flex;
    background: var(--vs-ring-bg);
    padding: var(--vs-espessura);
    box-shadow: 0 4px 14px rgba(32, 27, 20, 0.08);
    transition: box-shadow 0.3s ease;
  }
  .ame-vs__item:hover .ame-vs__ring {
    box-shadow: 0 8px 24px rgba(32, 27, 20, 0.16);
  }

  .ame-vs__media {
    position: relative;
    width: var(--vs-tamanho);
    overflow: hidden;
    background: var(--color-surface-container-highest, #ece1d5);
  }
  .ame-vs__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s var(--ease-luxury, cubic-bezier(0.22, 1, 0.36, 1));
  }
  .ame-vs__item:hover .ame-vs__media img { transform: scale(1.06); }

  .ame-vs__media-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(90, 71, 66, 0.4);
  }
  .ame-vs__media-fallback .material-symbols-outlined {
    font-size: calc(var(--vs-tamanho) * 0.4) !important;
  }

  .ame-vs__play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(32, 27, 20, 0);
    transition: background 0.25s ease;
    pointer-events: none;
  }
  .ame-vs__play .material-symbols-outlined {
    font-size: calc(var(--vs-tamanho) * 0.32) !important;
    color: rgba(255, 255, 255, 0);
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
    transform: scale(0.8);
    transition: color 0.25s ease, transform 0.25s ease;
    font-variation-settings: 'FILL' 1;
  }
  .ame-vs__item:hover .ame-vs__play {
    background: rgba(32, 27, 20, 0.18);
  }
  .ame-vs__item:hover .ame-vs__play .material-symbols-outlined {
    color: rgba(255, 255, 255, 0.95);
    transform: scale(1);
  }

  .ame-vs__title {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--color-on-background, #201b14);
    line-height: 1.3;
    text-align: center;
    width: var(--vs-tamanho);
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  /* ── Stories (círculos) ─────────────────── */
  .ame-vs--stories .ame-vs__ring,
  .ame-vs--stories .ame-vs__media {
    border-radius: 50%;
  }
  .ame-vs--stories .ame-vs__media {
    aspect-ratio: 1 / 1;
  }

  /* ── Carrossel (cards 9:16) ────────────── */
  .ame-vs--carrossel .ame-vs__ring {
    border-radius: var(--radius-md, 0.375rem);
  }
  .ame-vs--carrossel .ame-vs__media {
    aspect-ratio: 9 / 16;
    width: calc(var(--vs-tamanho) * 1.4);
    border-radius: var(--radius-sm, 0.25rem);
  }
  .ame-vs--carrossel .ame-vs__title {
    width: calc(var(--vs-tamanho) * 1.4);
    text-align: left;
  }

  /* ── Spotlight (card 16:9 grande) ──────── */
  .ame-vs--spotlight .ame-vs__track {
    flex-direction: column;
    overflow: visible;
  }
  .ame-vs--spotlight .ame-vs__item {
    width: 100%;
    align-items: stretch;
  }
  .ame-vs--spotlight .ame-vs__ring {
    border-radius: var(--radius-lg, 0.5rem);
    width: 100%;
  }
  .ame-vs--spotlight .ame-vs__media {
    aspect-ratio: 16 / 9;
    width: 100%;
    min-height: 240px;
    border-radius: var(--radius-md, 0.375rem);
  }
  .ame-vs--spotlight .ame-vs__title {
    width: 100%;
    text-align: left;
    font-size: 0.9375rem;
    margin-top: 0.5rem;
    -webkit-line-clamp: 1;
  }
  .ame-vs--spotlight .ame-vs__play .material-symbols-outlined {
    font-size: 4rem !important;
  }

  /* ── Modal player ──────────────────────── */
  .ame-vs-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    background: rgba(32, 27, 20, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }
  .ame-vs-modal[hidden] { display: none; }
  .ame-vs-modal.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .ame-vs-modal__box {
    position: relative;
    width: 100%;
    max-width: 32rem;
    background: #000;
    border-radius: var(--radius-lg, 0.5rem);
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.6);
    transform: scale(0.96);
    transition: transform 0.3s var(--ease-luxury, cubic-bezier(0.22, 1, 0.36, 1));
  }
  .ame-vs-modal.is-open .ame-vs-modal__box { transform: scale(1); }

  .ame-vs-modal__close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 10;
    background: rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: none;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
  }
  .ame-vs-modal__close:hover { background: rgba(255, 255, 255, 0.3); }
  .ame-vs-modal__close .material-symbols-outlined {
    font-size: 1.25rem !important;
  }

  .ame-vs-modal__player {
    position: relative;
    aspect-ratio: 9 / 16;
    width: 100%;
    background: #000;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .ame-vs-modal__box { max-width: 24rem; }
  }
  .ame-vs-modal__player iframe,
  .ame-vs-modal__player video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    object-fit: contain;
    background: #000;
  }

  .ame-vs-modal__cta {
    background: linear-gradient(to top, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.5) 60%, transparent 100%);
    padding: 1.5rem 1rem 1rem;
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 5;
    pointer-events: none;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .ame-vs-modal__cta.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .ame-vs-modal__cta-title {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.875rem;
    color: #fff;
    margin: 0 0 0.625rem;
    font-weight: 500;
  }
  .ame-vs-modal__cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: #fff;
    color: var(--color-on-background, #201b14);
    border: none;
    border-radius: var(--radius-full, 999px);
    padding: 0.625rem 1.125rem;
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s ease;
  }
  .ame-vs-modal__cta-btn:hover { transform: scale(1.03); }
  .ame-vs-modal__cta-btn .material-symbols-outlined {
    font-size: 1rem !important;
  }
</style>

<script>
  (() => {
    if (window.AmeVideoStories) {
      window.AmeVideoStories.bindAll();
      return;
    }

    const AUTOPLAY_DEFAULT = {{ vs_autoplay | json }};

    function ensureModal() {
      let modal = document.getElementById('ame-vs-modal');
      if (modal) return modal;

      modal = document.createElement('div');
      modal.id = 'ame-vs-modal';
      modal.className = 'ame-vs-modal';
      modal.hidden = true;
      modal.setAttribute('role', 'dialog');
      modal.setAttribute('aria-modal', 'true');
      modal.setAttribute('aria-label', 'Reprodutor de vídeo');
      modal.innerHTML = `
        <div class="ame-vs-modal__box" data-vs-modal-box>
          <button type="button" class="ame-vs-modal__close" data-vs-modal-close aria-label="Fechar">
            <span class="material-symbols-outlined">close</span>
          </button>
          <div class="ame-vs-modal__player" data-vs-modal-player></div>
          <div class="ame-vs-modal__cta" data-vs-modal-cta>
            <p class="ame-vs-modal__cta-title" data-vs-modal-cta-title></p>
            <a class="ame-vs-modal__cta-btn" data-vs-modal-cta-link>
              <span data-vs-modal-cta-label></span>
              <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
            </a>
          </div>
        </div>
      `;
      document.body.appendChild(modal);

      modal.addEventListener('click', (e) => {
        if (e.target === modal || e.target.closest('[data-vs-modal-close]')) {
          closeModal();
        }
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
      });
      return modal;
    }

    function buildPlayer(data) {
      const autoplay = AUTOPLAY_DEFAULT ? '1' : '0';
      const muted = AUTOPLAY_DEFAULT ? '1' : '0';
      if (data.type === 'external' && data.host === 'youtube') {
        return `<iframe
          src="https://www.youtube.com/embed/${encodeURIComponent(data.id)}?autoplay=${autoplay}&mute=${muted}&rel=0&playsinline=1&modestbranding=1"
          allow="autoplay; encrypted-media; picture-in-picture"
          allowfullscreen></iframe>`;
      }
      if (data.type === 'external' && data.host === 'vimeo') {
        return `<iframe
          src="https://player.vimeo.com/video/${encodeURIComponent(data.id)}?autoplay=${autoplay}&muted=${muted}&playsinline=1"
          allow="autoplay; encrypted-media; picture-in-picture"
          allowfullscreen></iframe>`;
      }
      if (data.type === 'native' && data.src) {
        return `<video
          src="${data.src.replace(/"/g, '&quot;')}"
          ${AUTOPLAY_DEFAULT ? 'autoplay muted' : ''}
          controls
          playsinline></video>`;
      }
      return '<p style="color:#fff;text-align:center;padding:2rem;">Vídeo indisponível.</p>';
    }

    function openModal(data) {
      const modal = ensureModal();
      const player = modal.querySelector('[data-vs-modal-player]');
      const cta = modal.querySelector('[data-vs-modal-cta]');
      const ctaLink = modal.querySelector('[data-vs-modal-cta-link]');
      const ctaLabel = modal.querySelector('[data-vs-modal-cta-label]');
      const ctaTitle = modal.querySelector('[data-vs-modal-cta-title]');

      player.innerHTML = buildPlayer(data);

      if (data.ctaUrl) {
        ctaLink.href = data.ctaUrl;
        ctaLabel.textContent = data.ctaLabel || 'Ver mais';
        ctaTitle.textContent = data.title || '';
        ctaTitle.style.display = data.title ? '' : 'none';
        cta.classList.add('is-visible');
      } else {
        cta.classList.remove('is-visible');
      }

      modal.hidden = false;
      requestAnimationFrame(() => modal.classList.add('is-open'));
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      const modal = document.getElementById('ame-vs-modal');
      if (!modal) return;
      const player = modal.querySelector('[data-vs-modal-player]');
      modal.classList.remove('is-open');
      document.body.style.overflow = '';
      setTimeout(() => {
        if (player) player.innerHTML = '';
        modal.hidden = true;
      }, 250);
    }

    function bindOne(btn) {
      if (btn.dataset.vsBound) return;
      btn.dataset.vsBound = '1';
      btn.addEventListener('click', () => {
        openModal({
          type: btn.dataset.vsType,
          id: btn.dataset.vsId,
          host: btn.dataset.vsHost,
          src: btn.dataset.vsSrc,
          title: btn.dataset.vsTitle,
          ctaUrl: btn.dataset.vsCtaUrl,
          ctaLabel: btn.dataset.vsCtaLabel,
        });
      });
    }

    function bindAll() {
      document.querySelectorAll('[data-vs-open]').forEach(bindOne);
    }

    window.AmeVideoStories = { open: openModal, close: closeModal, bindAll };
    bindAll();
  })();
</script>
{%- endif -%}
