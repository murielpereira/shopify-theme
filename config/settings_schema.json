[
  {
    "name": "theme_info",
    "theme_name": "Âme Acessórios Pet",
    "theme_version": "1.0.0",
    "theme_author": "Âme",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "Tipografia",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "lexend_n4",
        "label": "Fonte principal"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "Largura máxima da página",
        "options": [
          { "value": "90rem",  "label": "Estreito (90rem)" },
          { "value": "110rem", "label": "Largo (110rem)" },
          { "value": "120rem", "label": "Full (120rem)" }
        ],
        "default": "120rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 16,
        "max": 120,
        "step": 8,
        "unit": "px",
        "label": "Margem lateral (desktop)",
        "default": 64
      },
      {
        "type": "range",
        "id": "section_gap",
        "min": 60,
        "max": 160,
        "step": 10,
        "unit": "px",
        "label": "Espaçamento entre seções",
        "default": 120
      },
      {
        "type": "range",
        "id": "border_radius_base",
        "min": 0,
        "max": 16,
        "step": 2,
        "unit": "px",
        "label": "Arredondamento base (md)",
        "info": "Aplica-se a botões, inputs e cards. lg = 2×, sm = 0.5×.",
        "default": 4
      }
    ]
  },
  {
    "name": "Cores",
    "settings": [
      {
        "type": "header",
        "content": "Cor Principal"
      },
      {
        "type": "paragraph",
        "content": "Usada em botões primários, links ativos, bordas de seleção e ícones."
      },
      {
        "type": "color",
        "id": "color_primary",
        "default": "#5a4742",
        "label": "Cor Principal"
      },
      {
        "type": "color",
        "id": "color_primary_container",
        "default": "#735e59",
        "label": "Cor Principal — variação (gradiente)"
      },
      {
        "type": "color",
        "id": "color_on_primary",
        "default": "#ffffff",
        "label": "Texto sobre Cor Principal"
      },
      {
        "type": "header",
        "content": "Cor Secundária"
      },
      {
        "type": "paragraph",
        "content": "Usada em chips, badges e elementos de apoio."
      },
      {
        "type": "color",
        "id": "color_secondary",
        "default": "#655d54",
        "label": "Cor Secundária"
      },
      {
        "type": "color",
        "id": "color_secondary_container",
        "default": "#e9ded2",
        "label": "Container Secundário"
      },
      {
        "type": "header",
        "content": "Fundo e Superfícies"
      },
      {
        "type": "paragraph",
        "content": "Fundo da página e das seções. Sem linhas — use variações de tom para separar áreas."
      },
      {
        "type": "color",
        "id": "color_background",
        "default": "#fff8f3",
        "label": "Fundo da Página"
      },
      {
        "type": "color",
        "id": "color_surface_container",
        "default": "#f8ece0",
        "label": "Superfície — Container (cards, seções)"
      },
      {
        "type": "color",
        "id": "color_surface_container_high",
        "default": "#f2e6da",
        "label": "Superfície — Container Alto (hover, destaque)"
      },
      {
        "type": "header",
        "content": "Texto"
      },
      {
        "type": "color",
        "id": "color_on_background",
        "default": "#201b14",
        "label": "Texto Principal"
      },
      {
        "type": "color",
        "id": "color_on_surface_variant",
        "default": "#4f4442",
        "label": "Texto Secundário"
      },
      {
        "type": "header",
        "content": "Barra de Anúncios"
      },
      {
        "type": "color",
        "id": "color_announce_bg",
        "default": "#5a4742",
        "label": "Fundo da barra de anúncios"
      },
      {
        "type": "color",
        "id": "color_announce_text",
        "default": "#ffffff",
        "label": "Texto da barra de anúncios"
      },
      {
        "type": "header",
        "content": "Botão Primário (CTA)"
      },
      {
        "type": "color",
        "id": "color_btn_primary_bg",
        "default": "#5a4742",
        "label": "Fundo do botão"
      },
      {
        "type": "color",
        "id": "color_btn_primary_text",
        "default": "#ffffff",
        "label": "Texto do botão"
      },
      {
        "type": "header",
        "content": "Bordas e Divisores"
      },
      {
        "type": "color",
        "id": "color_outline_variant",
        "default": "#d2c3c0",
        "label": "Borda sutil (inputs, divisores)"
      }
    ]
  },
  {
    "name": "Cabeçalho",
    "settings": [
      {
        "type": "checkbox",
        "id": "header_sticky",
        "label": "Cabeçalho fixo ao rolar",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "header_transparent",
        "label": "Transparente sobre o hero",
        "default": true
      }
    ]
  },
  {
    "name": "Carrinho",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Tipo de carrinho",
        "options": [
          { "value": "page",   "label": "Página de carrinho" },
          { "value": "drawer", "label": "Gaveta lateral" }
        ],
        "default": "drawer"
      }
    ]
  },
  {
    "name": "Cashback",
    "settings": [
      {
        "type": "checkbox",
        "id": "cashback_enabled",
        "label": "Exibir cashback",
        "default": true,
        "info": "Mostra o valor de cashback na página de produto e nos cards."
      },
      {
        "type": "range",
        "id": "cashback_percent",
        "min": 1,
        "max": 30,
        "step": 0.5,
        "unit": "%",
        "label": "Porcentagem de cashback",
        "default": 8
      },
      {
        "type": "range",
        "id": "cashback_min_value",
        "min": 1,
        "max": 50,
        "step": 1,
        "unit": "R$",
        "label": "Valor mínimo para exibir cashback (R$)",
        "default": 10
      },
      {
        "type": "color",
        "id": "cashback_color",
        "label": "Cor do ícone e texto de cashback",
        "default": "#5a4742"
      }
    ]
  },
  {
    "name": "Redes Sociais",
    "settings": [
      {
        "type": "url",
        "id": "social_instagram",
        "label": "Instagram"
      },
      {
        "type": "url",
        "id": "social_facebook",
        "label": "Facebook"
      },
      {
        "type": "url",
        "id": "social_whatsapp",
        "label": "WhatsApp"
      }
    ]
  }
]
