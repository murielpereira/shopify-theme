[
  {
    "name": "theme_info",
    "theme_name": "Âme Acessórios Pet",
    "theme_version": "1.0.0",
    "theme_author": "Âme",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "Tipografia",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "label": "Fonte principal",
        "default": "assistant_n4"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "Largura máxima da página",
        "options": [
          { "value": "90rem",  "label": "Estreito (90rem)" },
          { "value": "110rem", "label": "Largo (110rem)" },
          { "value": "120rem", "label": "Full (120rem)" }
        ],
        "default": "120rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 16,
        "max": 250,
        "step": 6,
        "unit": "px",
        "label": "Margem lateral (desktop)",
        "default": 64
      },
      {
        "type": "range",
        "id": "section_gap",
        "min": 60,
        "max": 160,
        "step": 10,
        "unit": "px",
        "label": "Espaçamento entre seções",
        "default": 120
      },
      {
        "type": "range",
        "id": "border_radius_base",
        "min": 0,
        "max": 16,
        "step": 2,
        "unit": "px",
        "label": "Arredondamento base (md)",
        "info": "Aplica-se a botões, inputs e cards. lg = 2×, sm = 0.5×.",
        "default": 4
      }
    ]
  },
  {
    "name": "Cores",
    "settings": [
      {
        "type": "header",
        "content": "Cor Principal"
      },
      {
        "type": "paragraph",
        "content": "Usada em botões primários, links ativos, bordas de seleção e ícones."
      },
      {
        "type": "color",
        "id": "color_primary",
        "default": "#5a4742",
        "label": "Cor Principal"
      },
      {
        "type": "color",
        "id": "color_primary_container",
        "default": "#735e59",
        "label": "Cor Principal — variação (gradiente)"
      },
      {
        "type": "color",
        "id": "color_on_primary",
        "default": "#ffffff",
        "label": "Texto sobre Cor Principal"
      },
      {
        "type": "header",
