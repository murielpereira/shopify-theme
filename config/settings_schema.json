      { "type": "select", "id": "custom_field_1_type", "label": "Tipo do campo", "default": "text", "options": [{ "value": "text", "label": "Texto curto" }, { "value": "long_text", "label": "Texto longo" }, { "value": "date", "label": "Data" }, { "value": "radio", "label": "Seleção (botões)" }] },
