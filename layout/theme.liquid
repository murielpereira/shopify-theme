<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {%- render 'css-variables' -%}

    {%- unless settings.type_primary_font.system? -%}
      {%- assign font_url = settings.type_primary_font | font_url -%}
      {%- if font_url -%}
        <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
        {{ font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
      {%- endif -%}
    {%- endunless -%}

    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {%- render 'meta-tags' -%}

    {{ content_for_header }}
  </head>

  <body>
    {%- sections 'header-group' -%}

    <main id="main-content" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {%- sections 'footer-group' -%}

    <script>
      /* Scroll reveal — shared across all pages */
      document.addEventListener('DOMContentLoaded', () => {
        const reveals = document.querySelectorAll('.ame-reveal');
        if (!reveals.length) return;
        const io = new IntersectionObserver((entries) => {
          entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('is-visible'); });
        }, { threshold: 0.1 });
        reveals.forEach(el => io.observe(el));
      });
    </script>
  </body>
</html>
