{% doc %}
  @prompt
    Uma linha do tempo vertical interativa que se destaca conforme o usuário rola a página
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-timeline-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 60px 0;
  }

  .ai-timeline-container-{{ ai_gen_id }} {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-timeline-line-{{ ai_gen_id }} {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: {{ block.settings.line_width }}px;
    background-color: {{ block.settings.line_color }};
    transform: translateX(-50%);
    z-index: 1;
  }

  .ai-timeline-progress-{{ ai_gen_id }} {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 0%;
    background: {{ block.settings.line_active_color }};
    transition: height 0.3s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }} {
    position: relative;
    margin-bottom: 80px;
    opacity: 0.3;
    transition: opacity 0.5s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-timeline-item-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-timeline-content-{{ ai_gen_id }} {
    position: relative;
    width: calc(50% - 40px);
    padding: 24px;
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-timeline-item-{{ ai_gen_id }}:nth-child(odd) .ai-timeline-content-{{ ai_gen_id }} {
    margin-left: 0;
    margin-right: auto;
  }

  .ai-timeline-item-{{ ai_gen_id }}:nth-child(even) .ai-timeline-content-{{ ai_gen_id }} {
    margin-left: auto;
    margin-right: 0;
  }

  .ai-timeline-marker-{{ ai_gen_id }} {
    position: absolute;
    left: 50%;
    top: 30px;
    width: {{ block.settings.marker_size }}px;
    height: {{ block.settings.marker_size }}px;
    background-color: {{ block.settings.marker_color }};
    border: {{ block.settings.marker_border_width }}px solid {{ block.settings.marker_border_color }};
    border-radius: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    transition: all 0.3s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active .ai-timeline-marker-{{ ai_gen_id }} {
    background-color: {{ block.settings.marker_active_color }};
    border-color: {{ block.settings.marker_active_border_color }};
    transform: translate(-50%, -50%) scale(1.2);
  }

  .ai-timeline-date-{{ ai_gen_id }} {
    font-size: {{ block.settings.date_font_size }}px;
    color: {{ block.settings.date_color }};
    font-weight: 600;
    margin-bottom: 8px;
  }

  .ai-timeline-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    font-weight: 700;
    margin: 0 0 12px 0;
  }

  .ai-timeline-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
  }

  @media screen and (max-width: 768px) {
    .ai-timeline-line-{{ ai_gen_id }} {
      left: 20px;
    }

    .ai-timeline-content-{{ ai_gen_id }} {
      width: calc(100% - 60px);
      margin-left: 60px !important;
      margin-right: 0 !important;
    }

    .ai-timeline-marker-{{ ai_gen_id }} {
      left: 20px;
    }

    .ai-timeline-item-{{ ai_gen_id }} {
      margin-bottom: 60px;
    }
  }
{% endstyle %}

<interactive-timeline-{{ ai_gen_id }} class="ai-timeline-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-timeline-container-{{ ai_gen_id }}">
    <div class="ai-timeline-line-{{ ai_gen_id }}">
      <div class="ai-timeline-progress-{{ ai_gen_id }}"></div>
    </div>

    {% for i in (1..6) %}
      {% liquid
        assign date_key = 'item_' | append: i | append: '_date'
        assign title_key = 'item_' | append: i | append: '_title'
        assign description_key = 'item_' | append: i | append: '_description'
        assign enabled_key = 'item_' | append: i | append: '_enabled'

        assign item_date = block.settings[date_key]
        assign item_title = block.settings[title_key]
        assign item_description = block.settings[description_key]
        assign item_enabled = block.settings[enabled_key]
      %}

      {% if item_enabled %}
        <div class="ai-timeline-item-{{ ai_gen_id }}" data-timeline-item>
          <div class="ai-timeline-marker-{{ ai_gen_id }}"></div>
          <div class="ai-timeline-content-{{ ai_gen_id }}">
            {% if item_date != blank %}
              <div class="ai-timeline-date-{{ ai_gen_id }}">{{ item_date }}</div>
            {% endif %}
            {% if item_title != blank %}
              <h3 class="ai-timeline-title-{{ ai_gen_id }}">{{ item_title }}</h3>
            {% endif %}
            {% if item_description != blank %}
              <div class="ai-timeline-description-{{ ai_gen_id }}">{{ item_description }}</div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</interactive-timeline-{{ ai_gen_id }}>

<script>
  (function() {
    class InteractiveTimeline{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.items = [];
        this.progressBar = null;
        this.timelineLine = null;
      }

      connectedCallback() {
        this.items = Array.from(this.querySelectorAll('[data-timeline-item]'));
        this.progressBar = this.querySelector('.ai-timeline-progress-{{ ai_gen_id }}');
        this.timelineLine = this.querySelector('.ai-timeline-line-{{ ai_gen_id }}');
        
        if (this.items.length === 0) return;

        this.handleScroll = this.handleScroll.bind(this);
        window.addEventListener('scroll', this.handleScroll);
        this.handleScroll();
      }

      disconnectedCallback() {
        window.removeEventListener('scroll', this.handleScroll);
      }

      handleScroll() {
        const windowHeight = window.innerHeight;
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        
        if (!this.timelineLine) return;

        const lineRect = this.timelineLine.getBoundingClientRect();
        const lineTop = lineRect.top + scrollTop;
        const lineHeight = lineRect.height;

        let activeCount = 0;

        this.items.forEach((item, index) => {
          const itemRect = item.getBoundingClientRect();
          const itemTop = itemRect.top + scrollTop;
          const itemMiddle = itemTop + (itemRect.height / 2);

          const triggerPoint = scrollTop + (windowHeight * 0.7);

          if (triggerPoint >= itemMiddle) {
            item.classList.add('active');
            activeCount = index + 1;
          } else {
            item.classList.remove('active');
          }
        });

        if (this.items.length > 0 && this.progressBar) {
          const lastActiveItem = this.items[activeCount - 1];
          if (lastActiveItem) {
            const lastItemRect = lastActiveItem.getBoundingClientRect();
            const lastItemTop = lastItemRect.top + scrollTop;
            const progressHeight = ((lastItemTop - lineTop) / lineHeight) * 100;
            this.progressBar.style.height = Math.min(Math.max(progressHeight, 0), 100) + '%';
          } else {
            this.progressBar.style.height = '0%';
          }
        }
      }
    }

    customElements.define('interactive-timeline-{{ ai_gen_id }}', InteractiveTimeline{{ ai_gen_id }});
  })();
</script>

