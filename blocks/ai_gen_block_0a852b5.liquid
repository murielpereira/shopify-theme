      "label": "Categoria",
      "default": "Novidades"
    },
    {
      "type": "text",
      "id": "feature_title",
      "label": "Título",
      "default": "Descubra a nova coleção de acessórios para pets"
    },
    {
      "type": "textarea",
      "id": "feature_excerpt",
      "label": "Resumo",
      "default": "Conheça os produtos que vão deixar seu pet ainda mais estiloso e confortável nesta temporada."
    },
    {
      "type": "url",
      "id": "feature_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Artigo 1"
    },
    {
      "type": "image_picker",
      "id": "card_1_image",
      "label": "Imagem"
    },
    {
      "type": "text",
      "id": "card_1_category",
      "label": "Categoria",
      "default": "Dicas"
    },
    {
      "type": "text",
      "id": "card_1_title",
      "label": "Título",
      "default": "Como escolher a coleira ideal para seu pet"
    },
    {
      "type": "url",
      "id": "card_1_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Artigo 2"
    },
    {
      "type": "image_picker",
      "id": "card_2_image",
      "label": "Imagem"
    },
    {
      "type": "text",
      "id": "card_2_category",
      "label": "Categoria",
      "default": "Tendências"
    },
    {
      "type": "text",
      "id": "card_2_title",
      "label": "Título",
      "default": "Cores e estampas em alta para pets"
    },
    {
      "type": "url",
      "id": "card_2_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Artigo 3"
    },
    {
      "type": "image_picker",
      "id": "card_3_image",
      "label": "Imagem"
    },
    {
      "type": "text",
      "id": "card_3_category",
      "label": "Categoria",
      "default": "Cuidados"
    },
    {
      "type": "text",
      "id": "card_3_title",
      "label": "Título",
      "default": "Manutenção e limpeza de acessórios"
    },
    {
      "type": "url",
      "id": "card_3_link",
      "label": "Link"
