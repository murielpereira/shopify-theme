{% doc %}
  @prompt
    Adicione uma grade de produtos com titulo, subtitulo, seletor de qual coleção vai ser exibida na grade, seletor de quantidade de produtos por linha e botão ver mais para expandir a exibição para mais linhas., a exibição do card do produto esta diferente do restante do site. Preciso que fique no mesmo padrão., O product.card atual tem o seguinte código:
    {% comment %}
      Reutilizável — card de produto
      Parâmetros:
        card_product    — objeto product (obrigatório)
        card_show_badge — boolean (opcional)
        card_btn_label  — string (opcional, default "Comprar")
    {% endcomment %}
    
    {%- liquid
      assign card_url = card_product.url
      assign card_title = card_product.title
      assign card_img = card_product.featured_image
      assign card_cta_label = card_btn_label | default: 'Comprar'
    
      assign card_has_discount = false
      assign card_discount_pct = 0
      assign card_compare = card_product.compare_at_price_max | default: 0
      if card_compare == 0
        assign card_cv = card_product.selected_or_first_available_variant
        assign card_compare = card_cv.compare_at_price | default: 0
      endif
      assign card_price = card_product.price_min | default: card_product.price
      if card_compare > card_price
        assign card_has_discount = true
        assign card_discount_pct = card_compare | minus: card_price | times: 100 | divided_by: card_compare | round
      endif
    
      assign card_effective_price = card_product.price
      if card_has_discount == false and settings.auto_discount_enabled and settings.auto_discount_percent > 0
        assign card_has_discount = true
        assign card_discount_pct = settings.auto_discount_percent
        assign card_compare_price = card_product.price
        assign card_discount_cents = card_product.price | times: card_discount_pct | divided_by: 100
        assign card_effective_price = card_product.price | minus: card_discount_cents
      else
        assign card_compare_price = card_compare
      endif
    
      assign card_badge = ''
      if card_product.tags contains 'heritage'
        assign card_badge = 'Heritage'
      elsif card_product.tags contains 'novo'
        assign card_badge = 'Novo'
      elsif card_product.tags contains 'mais-vendido'
        assign card_badge = 'Mais Vendido'
      endif
    
      assign card_rating = card_product.metafields.reviews.rating.value
    
      assign pix_pct = settings.pix_discount | default: 5
      assign pix_cents = card_effective_price | times: pix_pct | divided_by: 100
      assign pix_cents = card_effective_price | minus: pix_cents
      assign inst_count = settings.installments_count | default: 3
      assign inst_value = card_effective_price | divided_by: inst_count
    -%}
    
    <div class="ame-card" data-product-card>
      <a href="{{ card_url }}" class="ame-card__link" tabindex="-1" aria-hidden="true">
        <div class="ame-card__image-wrap">
          {%- if card_img != blank -%}
            {%- assign card_img_alt = card_img.alt | default: card_title | escape -%}
            {{ card_img | image_url: width: 600 | image_tag: loading: 'lazy', widths: '200, 400, 600', class: 'ame-card__img', alt: card_img_alt }}
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'ame-card__img ame-card__img--placeholder' }}
          {%- endif -%}
    
          <!-- Desconto top-left -->
          {%- if card_has_discount -%}
            <span class="ame-card__discount-badge" aria-label="{{ card_discount_pct }}% de desconto">
              {{ card_discount_pct }}% OFF
            </span>
          {%- endif -%}
    
          <!-- Badge de texto (Heritage / Novo / Mais Vendido) bottom-left -->
          {%- if card_badge != '' -%}
            <span class="ame-chip ame-chip--primary ame-card__badge">{{ card_badge }}</span>
          {%- endif -%}
    
          <!-- Avaliação top-right -->
          {%- if card_rating != blank -%}
            <span class="ame-card__rating-badge" aria-label="Avaliação: {{ card_rating }}">
              <span class="material-symbols-outlined ame-card__rating-star" aria-hidden="true">star</span>
              {{ card_rating }}
            </span>
          {%- endif -%}
    
          <!-- Favorito bottom-right -->
          <button
            class="ame-wishlist ame-card__wishlist"
            aria-label="Adicionar aos favoritos"
            data-wishlist-btn="{{ card_product.id }}"
            type="button"
            aria-pressed="false"
          >
            <span class="material-symbols-outlined" aria-hidden="true" style="font-size:1.125rem; font-variation-settings:'FILL' 0;"
              >favorite</span
            >
          </button>
        </div>
      </a>
    
      <div class="ame-card__info">
        {%- if card_product.metafields.custom.collection_name != blank -%}
          <p class="ame-card__collection">{{ card_product.metafields.custom.collection_name }}</p>
        {%- elsif card_product.collections.first != blank -%}
          <p class="ame-card__collection">{{ card_product.collections.first.title }}</p>
        {%- endif -%}
    
        <h3 class="ame-card__title">
          <a href="{{ card_url }}">{{ card_title }}</a>
        </h3>
    
        <!-- Bloco de preços -->
        <div class="ame-card__prices">
          {%- if card_has_discount -%}
            <p class="ame-card__price-de">
              De: <s>{{ card_compare_price | money }}</s>
            </p>
          {%- endif -%}
    
          <p class="ame-card__price-main">
            <span class="ame-card__price-label">a partir de</span>
            <strong class="ame-card__price-value">{{ card_effective_price | money }}</strong>
          </p>
    
          {%- if settings.show_installments != false and inst_count > 1 -%}
          
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-product-grid__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-product-grid__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-product-grid__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-product-grid__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: 32px;
  }

  @media screen and (max-width: 749px) {
    .ai-product-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_mobile }}, 1fr);
    }
  }

  .ai-product-grid__item-{{ ai_gen_id }} {
    display: none;
  }

  .ai-product-grid__item-{{ ai_gen_id }}.visible {
    display: block;
  }

  .ai-product-grid__footer-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-product-grid__button-{{ ai_gen_id }} {
    padding: 14px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-product-grid__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  .ai-product-grid__button-{{ ai_gen_id }}.hidden {
    display: none;
  }

  .ai-product-grid__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
    font-size: 16px;
  }
{% endstyle %}

<product-grid-{{ ai_gen_id }} class="ai-product-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.title != blank or block.settings.subtitle != blank %}
    <div class="ai-product-grid__header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-product-grid__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <p class="ai-product-grid__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>
  {% endif %}

  {% if block.settings.collection != blank %}
    {% assign collection = block.settings.collection %}
    {% assign products = collection.products %}
    {% assign initial_rows = block.settings.initial_rows %}
    {% assign products_per_row = block.settings.products_per_row %}
    {% assign initial_count = initial_rows | times: products_per_row %}

    {% if products.size > 0 %}
      <div class="ai-product-grid__grid-{{ ai_gen_id }}">
        {% for product in products %}
          <div class="ai-product-grid__item-{{ ai_gen_id }} {% if forloop.index <= initial_count %}visible{% endif %}" data-index="{{ forloop.index }}">
            {% liquid
              assign card_product = product
              assign card_url = card_product.url
              assign card_title = card_product.title
              assign card_img = card_product.featured_image

              assign card_has_discount = false
              assign card_discount_pct = 0
              assign card_compare = card_product.compare_at_price_max | default: 0
              if card_compare == 0
                assign card_cv = card_product.selected_or_first_available_variant
                assign card_compare = card_cv.compare_at_price | default: 0
              endif
              assign card_price = card_product.price_min | default: card_product.price
              if card_compare > card_price
                assign card_has_discount = true
                assign card_discount_pct = card_compare | minus: card_price | times: 100 | divided_by: card_compare | round
              endif

              assign card_effective_price = card_product.price
              if card_has_discount == false and settings.auto_discount_enabled and settings.auto_discount_percent > 0
                assign card_has_discount = true
                assign card_discount_pct = settings.auto_discount_percent
                assign card_compare_price = card_product.price
                assign card_discount_cents = card_product.price | times: card_discount_pct | divided_by: 100
                assign card_effective_price = card_product.price | minus: card_discount_cents
              else
                assign card_compare_price = card_compare
              endif

              assign card_badge = ''
              if card_product.tags contains 'heritage'
                assign card_badge = 'Heritage'
              elsif card_product.tags contains 'novo'
                assign card_badge = 'Novo'
              elsif card_product.tags contains 'mais-vendido'
                assign card_badge = 'Mais Vendido'
              endif

              assign card_rating = card_product.metafields.reviews.rating.value

              assign pix_pct = settings.pix_discount | default: 5
              assign pix_cents = card_effective_price | times: pix_pct | divided_by: 100
              assign pix_price = card_effective_price | minus: pix_cents
              assign inst_count = settings.installments_count | default: 3
              assign inst_value = card_effective_price | divided_by: inst_count
            %}

            <div class="ame-card" data-product-card>
              <a href="{{ card_url }}" class="ame-card__link" tabindex="-1" aria-hidden="true">
                <div class="ame-card__image-wrap">
                  {% if card_img != blank %}
                    {% assign card_img_alt = card_img.alt | default: card_title | escape %}
                    {{ card_img | image_url: width: 600 | image_tag: loading: 'lazy', widths: '200, 400, 600', class: 'ame-card__img', alt: card_img_alt }}
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'ame-card__img ame-card__img--placeholder' }}
                  {% endif %}

                  {% if card_has_discount %}
                    <span class="ame-card__discount-badge" aria-label="{{ card_discount_pct }}% de desconto">
                      {{ card_discount_pct }}% OFF
                    </span>
                  {% endif %}

                  {% if card_badge != '' %}
                    <span class="ame-chip ame-chip--primary ame-card__badge">{{ card_badge }}</span>
                  {% endif %}

                  {% if card_rating != blank %}
                    <span class="ame-card__rating-badge" aria-label="Avaliação: {{ card_rating }}">
                      <span class="material-symbols-outlined ame-card__rating-star" aria-hidden="true">star</span>
                      {{ card_rating }}
                    </span>
                  {% endif %}

                  <button
                    class="ame-wishlist ame-card__wishlist"
                    aria-label="Adicionar aos favoritos"
                    data-wishlist-btn="{{ card_product.id }}"
                    type="button"
                    aria-pressed="false"
                  >
                    <span class="material-symbols-outlined" aria-hidden="true" style="font-size:1.125rem; font-variation-settings:'FILL' 0;">favorite</span>
                  </button>
                </div>
              </a>

              <div class="ame-card__info">
                {% if card_product.metafields.custom.collection_name != blank %}
                  <p class="ame-card__collection">{{ card_product.metafields.custom.collection_name }}</p>
                {% elsif card_product.collections.first != blank %}
                  <p class="ame-card__collection">{{ card_product.collections.first.title }}</p>
                {% endif %}

                <h3 class="ame-card__title">
                  <a href="{{ card_url }}">{{ card_title }}</a>
                </h3>

                <div class="ame-card__prices">
                  {% if card_has_discount %}
                    <p class="ame-card__price-de">
                      De: <s>{{ card_compare_price | money }}</s>
                    </p>
                  {% endif %}

                  <p class="ame-card__price-main">
                    <span class="ame-card__price-label">a partir de</span>
                    <strong class="ame-card__price-value">{{ card_effective_price | money }}</strong>
                  </p>

                  {% if settings.show_installments != false and inst_count > 1 %}
                    <p class="ame-card__installments">
                      ou {{ inst_count }}x de {{ inst_value | money }}
                      {% if settings.show_installments_link %}
                        <a href="{{ card_url }}" class="ame-card__installments-link">Ver mais detalhes</a>
                      {% endif %}
                    </p>
                  {% endif %}

                  {% if settings.show_pix != false %}
                    <p class="ame-card__pix">
                      <svg class="ame-card__pix-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M11.5 2.5L13.5 4.5M4.5 13.5L2.5 11.5M11.5 13.5L13.5 11.5M4.5 2.5L2.5 4.5M8 1V3M8 13V15M1 8H3M13 8H15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                      {{ pix_price | money }} no Pix
                    </p>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      {% if products.size > initial_count %}
        <div class="ai-product-grid__footer-{{ ai_gen_id }}">
          <button class="ai-product-grid__button-{{ ai_gen_id }}" data-load-more>
            {{ block.settings.button_text }}
          </button>
        </div>
      {% endif %}
    {% else %}
      <div class="ai-product-grid__empty-{{ ai_gen_id }}">
        Nenhum produto encontrado nesta coleção.
      </div>
    {% endif %}
  {% else %}
    <div class="ai-product-grid__empty-{{ ai_gen_id }}">
      Selecione uma coleção para exibir os produtos.
    </div>
  {% endif %}
</product-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.loadMoreButton = this.querySelector('[data-load-more]');
        this.items = this.querySelectorAll('.ai-product-grid__item-{{ ai_gen_id }}');
        this.productsPerRow = {{ block.settings.products_per_row }};
        this.currentVisibleCount = {{ block.settings.initial_rows | times: block.settings.products_per_row }};
      }

      connectedCallback() {
        if (this.loadMoreButton) {
          this.loadMoreButton.addEventListener('click', () => this.loadMore());
        }
      }

      loadMore() {
        const nextCount = this.currentVisibleCount + this.productsPerRow;
        
        for (let i = this.currentVisibleCount; i < nextCount && i < this.items.length; i++) {
          this.items[i].classList.add('visible');
        }
        
        this.currentVisibleCount = nextCount;
        
        if (this.currentVisibleCount >= this.items.length) {
          this.loadMoreButton.classList.add('hidden');
        }
      }
    }

    customElements.define('product-grid-{{ ai_gen_id }}', ProductGrid{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Grade de produtos",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Conteúdo"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Título",
      "default": "Nossos produtos"
    },
    {
      "type": "inline_richtext",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Descubra nossa seleção especial"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Coleção"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "products_per_row",
      "label": "Produtos por linha (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "products_per_row_mobile",
      "label": "Produtos por linha (mobile)",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "initial_rows",
      "label": "Linhas iniciais visíveis",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Espaçamento entre produtos",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Largura no desktop",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Botão ver mais"
    },
    {
      "type": "inline_richtext",
      "id": "button_text",
      "label": "Texto do botão",
      "default": "Ver mais produtos"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Cor de fundo",
      "default": "#5a4742"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Cor de fundo (hover)",
      "default": "#735e59"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Cor do texto",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Arredondamento do botão",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "header",
      "content": "Estilo dos títulos"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Tamanho do título",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Cor do título",
      "default": "#201b14"
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Tamanho do subtítulo",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Cor do subtítulo",
      "default": "#4f4442"
    }
  ],
  "presets": [
    {
      "name": "Grade de produtos"
    }
  ]
}
{% endschema %}
