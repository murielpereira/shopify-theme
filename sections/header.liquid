{% comment %} Âme — Header: glassmorphism + nav bar separada + logo imagem {% endcomment %}

{%- liquid
  assign logo_img_alt = section.settings.logo.alt | default: shop.name | escape
  assign logo_w = section.settings.logo_width
  assign logo_h_max = section.settings.logo_height
  assign logo_h = 0
  if section.settings.logo != blank and section.settings.logo.width > 0
    assign logo_h = section.settings.logo.height | times: logo_w | divided_by: section.settings.logo.width
  endif
-%}

<!-- Header group: sempre fixed, top ajustado pelo JS para ficar abaixo da announce -->
<div class="ame-header-group" data-header-group style="top: 2.5rem">
  <!-- Topo: logo + ações -->
  <header
    class="ame-header{% if settings.header_sticky %} ame-header--sticky{% endif %}"
    data-header
  >
    <!-- Logo -->
    <a href="{{ routes.root_url }}" class="ame-header__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        {{
          section.settings.logo
          | image_url: width: 560
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            class: 'ame-header__logo-img',
            alt: logo_img_alt,
            width: logo_w,
            height: logo_h
        }}
      {%- else -%}
        <span class="ame-header__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    <!-- Ações -->
    <div class="ame-header__actions" data-header-actions>
      <!-- Search inline (desktop: expande para a esquerda; mobile: abre overlay) -->
      <div class="ame-header__search-wrap" data-search-wrap>
        <form
          action="{{ routes.search_url }}"
          method="get"
          class="ame-header__search-form"
          data-search-form-inline
          role="search"
        >
          <input type="hidden" name="type" value="product">
          <input
            type="search"
            name="q"
            class="ame-header__search-input"
            placeholder="Buscar produtos…"
            autocomplete="off"
            aria-label="Buscar"
            data-predictive-input
          >
          <button
            type="button"
            class="ame-header__icon-btn ame-header__search-close"
            aria-label="Fechar busca"
            data-search-close
          >
            <span class="material-symbols-outlined">close</span>
          </button>
        </form>
      </div>

      <!-- Dropdown da busca preditiva (fora do search-wrap pra não ser clipado por overflow:hidden) -->
      <div
        class="ame-predictive"
        data-predictive-dropdown
        data-predictive-scope="desktop"
        aria-live="polite"
        hidden
      ></div>

      <button class="ame-header__icon-btn" aria-label="Buscar" data-search-toggle>
        <span class="material-symbols-outlined">search</span>
      </button>

      {%- if shop.customer_accounts_enabled -%}
        <a
          href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
          class="ame-header__icon-btn"
          aria-label="{% if customer %}Minha conta{% else %}Entrar{% endif %}"
        >
          <span class="material-symbols-outlined">person</span>
        </a>
      {%- endif -%}

      <button
        class="ame-header__icon-btn ame-header__cart"
        aria-label="Carrinho ({{ cart.item_count }} itens)"
        data-cart-open
      >
        <span class="material-symbols-outlined">shopping_bag</span>
        <span
          class="ame-header__cart-count"
          data-cart-count
          {% unless cart.item_count > 0 %}
            style="display:none"
          {% endunless %}
        >
          {{- cart.item_count -}}
        </span>
      </button>

      <button
        class="ame-header__icon-btn ame-header__mobile-menu-btn"
        aria-label="Menu"
        aria-expanded="false"
        data-mobile-menu-toggle
      >
        <span class="material-symbols-outlined" data-menu-icon>menu</span>
      </button>
    </div>
  </header>

  <!-- Nav bar secundária (desktop) -->
  <nav class="ame-header__nav-bar" aria-label="Menu principal" data-nav-bar>
    {%- for link in section.settings.menu.links -%}
      <a
        href="{{ link.url }}"
        class="ame-header__nav-link{% if link.active %} ame-header__nav-link--active{% endif %}"
        {% if link.current %}
          aria-current="page"
        {% endif %}
      >
        {{- link.title -}}
      </a>
    {%- endfor -%}
  </nav>
</div>

<!-- Search overlay mobile (desliza abaixo do header-group — apenas mobile) -->
<div class="ame-search-overlay" id="search-overlay" aria-hidden="true" data-search-overlay>
  <form action="{{ routes.search_url }}" method="get" class="ame-search-form" role="search">
    <input type="hidden" name="type" value="product">
    <span class="material-symbols-outlined ame-search-form__icon" aria-hidden="true">search</span>
    <input
      type="search"
      name="q"
      class="ame-search-form__input"
      placeholder="Buscar produtos…"
      autocomplete="off"
      aria-label="Buscar"
      data-predictive-input
    >
    <button type="button" class="ame-search-form__close" aria-label="Fechar busca" data-search-close-mobile>
      <span class="material-symbols-outlined">close</span>
    </button>
  </form>
  <div
    class="ame-predictive ame-predictive--mobile"
    data-predictive-dropdown
    aria-live="polite"
    hidden
  ></div>
</div>

<!-- Mobile nav drawer (fora do grupo fixed) -->
<nav class="ame-mobile-nav" id="mobile-nav" aria-hidden="true" data-mobile-nav>
  {%- for link in section.settings.menu.links -%}
    <a
      href="{{ link.url }}"
      class="ame-mobile-nav__link{% if link.active %} ame-mobile-nav__link--active{% endif %}"
    >
      {{- link.title -}}
    </a>
  {%- endfor -%}
</nav>

{% style %}
  :root {
    --logo-width:  {{ logo_w }}px;
    --logo-height: {{ logo_h_max }}px;
  }

  /* ── Predictive search dropdown ── */
  .ame-predictive {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    width: min(22rem, calc(100vw - 2rem));
    max-height: 70vh;
    overflow-y: auto;
    background: var(--color-background, #fff8f3);
    border: 1px solid rgba(210, 195, 192, 0.3);
    border-radius: var(--radius-lg, 0.5rem);
    box-shadow: 0 20px 40px rgba(32, 27, 20, 0.12);
    z-index: 90;
    padding: 0.5rem;
  }
  .ame-predictive[hidden] { display: none; }

  .ame-predictive--mobile {
    position: static;
    width: 100%;
    max-height: none;
    margin-top: 0.75rem;
    border: none;
    box-shadow: none;
    background: transparent;
    padding: 0;
  }

  .ame-predictive__list {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .ame-predictive__item {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.625rem;
    border-radius: var(--radius-md, 0.25rem);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease;
  }
  .ame-predictive__item:hover {
    background: var(--color-surface-container, #f8ece0);
  }

  .ame-predictive__thumb {
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-md, 0.25rem);
    overflow: hidden;
    background: var(--color-surface-container-highest, #ece1d5);
  }
  .ame-predictive__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ame-predictive__info {
    flex: 1;
    min-width: 0;
  }
  .ame-predictive__title {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-on-background, #201b14);
    margin: 0 0 0.125rem;
    line-height: 1.3;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .ame-predictive__price {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.75rem;
    color: var(--color-on-surface-variant, #4f4442);
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
  }
  .ame-predictive__price s {
    color: rgba(90, 71, 66, 0.45);
    font-size: 0.6875rem;
  }
  .ame-predictive__price strong {
    font-weight: 600;
    color: var(--color-on-background, #201b14);
  }

  .ame-predictive__all {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.875rem 0.625rem;
    margin-top: 0.5rem;
    border-top: 1px solid rgba(210, 195, 192, 0.2);
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary, #5a4742);
    text-decoration: none;
    font-weight: 600;
  }
  .ame-predictive__all:hover {
    color: var(--color-on-background, #201b14);
  }
  .ame-predictive__all .material-symbols-outlined {
    font-size: 1rem !important;
  }

  .ame-predictive__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.5rem 1rem;
    text-align: center;
  }
  .ame-predictive__empty .material-symbols-outlined {
    font-size: 2rem !important;
    color: rgba(90, 71, 66, 0.4);
  }
  .ame-predictive__empty p {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.8125rem;
    color: var(--color-on-surface-variant, #4f4442);
    margin: 0;
  }
{% endstyle %}

<script>
  (() => {
    const group = document.querySelector('[data-header-group]');
    const header = document.querySelector('[data-header]');
    const navBar = document.querySelector('[data-nav-bar]');
    const mobileNav = document.querySelector('[data-mobile-nav]');
    const menuBtn = document.querySelector('[data-mobile-menu-toggle]');
    const menuIcon = document.querySelector('[data-menu-icon]');
    const searchBtn = document.querySelector('[data-search-toggle]');
    const searchOverlay = document.querySelector('[data-search-overlay]');

    /*
      Arquitetura de posicionamento (todos fixed, JS controla top):
      ─ [data-countdown-bar]  z-index:300  top:0
      ─ [data-announce]       z-index:200  top: countdownH
      ─ [data-header-group]   z-index:100  top: countdownH + announceH
      ─ [data-search-overlay] z-index:98   top: countdownH + announceH + groupH
      ─ [data-mobile-nav]     z-index:99   top: countdownH + announceH + groupH

      Ao rolar: announce recebe .is-hidden (translateY(-100%)),
      e header-group sobe junto (top: countdownH).
      body.paddingTop = countdownH + announceH + groupH (sempre, para reservar espaço).
    */
    function layout() {
      if (!group) return;

      const countdown = document.querySelector('[data-countdown-bar]');
      const countdownH = countdown && countdown.offsetHeight > 0 ? countdown.offsetHeight : 0;

      const announce = document.querySelector('[data-announce]');
      const announceH = announce ? announce.offsetHeight : 0;

      const scrolled = window.scrollY > 10;

      // Announce: sobe para fora da tela ao rolar
      if (announce) {
        announce.style.top = countdownH + 'px';
        announce.classList.toggle('is-hidden', scrolled);
      }

      // Header-group: abaixo da announce quando no topo, sobe quando announce some
      const groupTop = scrolled ? countdownH : countdownH + announceH;
      group.style.top = groupTop + 'px';
      group.classList.toggle('is-sticky', scrolled);

      // Reserva espaço no body sempre com announce + countdown + header
      const totalPad = countdownH + announceH + group.offsetHeight;
      document.body.style.paddingTop = totalPad + 'px';

      // Search overlay e mobile nav: sempre abaixo do header-group
      const headerBottom = groupTop + group.offsetHeight;
      if (searchOverlay) searchOverlay.style.top = headerBottom + 'px';
      if (mobileNav) mobileNav.style.top = headerBottom + 'px';
    }

    layout();
    window.addEventListener('scroll', layout, { passive: true });
    window.addEventListener('resize', layout, { passive: true });

    if (window.ResizeObserver) {
      const ro = new ResizeObserver(layout);
      const announce = document.querySelector('[data-announce]');
      const countdown = document.querySelector('[data-countdown-bar]');
      if (announce) ro.observe(announce);
      if (countdown) ro.observe(countdown);
      if (group) ro.observe(group);
    }

    /* ── Scroll state (glassmorphism intensidade) ── */
    window.addEventListener(
      'scroll',
      () => {
        const scrolled = window.scrollY > 10;
        header?.classList.toggle('is-scrolled', scrolled);
        navBar?.classList.toggle('is-scrolled', scrolled);
      },
      { passive: true }
    );

    /* ── Search: inline no desktop, overlay no mobile ── */
    const searchWrap = document.querySelector('[data-search-wrap]');
    const searchInputInline = searchWrap?.querySelector('[data-predictive-input]');
    const searchCloseInline = document.querySelector('[data-search-close]');
    const searchInputMobile = searchOverlay?.querySelector('[data-predictive-input]');
    const searchCloseMobile = document.querySelector('[data-search-close-mobile]');

    const isDesktop = () => window.innerWidth >= 768;

    function openSearch() {
      if (isDesktop()) {
        searchWrap?.classList.add('is-open');
        setTimeout(() => searchInputInline?.focus(), 80);
      } else {
        searchOverlay?.classList.add('is-open');
        searchOverlay?.setAttribute('aria-hidden', 'false');
        setTimeout(() => searchInputMobile?.focus(), 80);
      }
    }
    function closeSearch() {
      searchWrap?.classList.remove('is-open');
      searchOverlay?.classList.remove('is-open');
      searchOverlay?.setAttribute('aria-hidden', 'true');
      document.querySelectorAll('[data-predictive-dropdown]').forEach(d => {
        d.hidden = true;
        d.innerHTML = '';
      });
    }

    searchBtn?.addEventListener('click', () => {
      const isOpen = isDesktop()
        ? searchWrap?.classList.contains('is-open')
        : searchOverlay?.classList.contains('is-open');
      isOpen ? closeSearch() : openSearch();
    });
    searchCloseInline?.addEventListener('click', closeSearch);
    searchCloseMobile?.addEventListener('click', closeSearch);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeSearch();
    });

    /* ── Predictive search (dropdown com sugestões em tempo real) ── */
    const PREDICTIVE_LIMIT = 6;
    const PREDICTIVE_DEBOUNCE_MS = 220;
    const SHOP_CURRENCY_FORMAT = {{ shop.money_format | json }};
    const moneyFmt = (cents) => {
      if (window.Shopify?.formatMoney) return window.Shopify.formatMoney(cents, SHOP_CURRENCY_FORMAT);
      return 'R$ ' + ((cents || 0) / 100).toFixed(2).replace('.', ',');
    };

    const escapeHTML = (str) => String(str ?? '').replace(/[&<>"']/g, c => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
    })[c]);

    function renderPredictiveDropdown(dropdown, query, products) {
      if (!dropdown) return;
      if (!query.trim()) {
        dropdown.hidden = true;
        dropdown.innerHTML = '';
        return;
      }
      if (!products || products.length === 0) {
        dropdown.innerHTML = `
          <div class="ame-predictive__empty">
            <span class="material-symbols-outlined" aria-hidden="true">search_off</span>
            <p>Nenhum produto encontrado para <strong>"${escapeHTML(query)}"</strong>.</p>
          </div>
        `;
        dropdown.hidden = false;
        return;
      }
      const items = products.map(p => {
        const img = p.featured_image?.url || p.image || '';
        const title = escapeHTML(p.title || '');
        const url = p.url || '#';
        const priceCents = p.price_min ?? p.price ?? 0;
        const compareCents = p.compare_at_price_min ?? p.compare_at_price ?? 0;
        const hasCompare = compareCents > priceCents;
        return `
          <a class="ame-predictive__item" href="${escapeHTML(url)}">
            <div class="ame-predictive__thumb">
              ${img ? `<img src="${escapeHTML(img)}" alt="${title}" loading="lazy">` : ''}
            </div>
            <div class="ame-predictive__info">
              <p class="ame-predictive__title">${title}</p>
              <p class="ame-predictive__price">
                ${hasCompare ? `<s>${moneyFmt(compareCents)}</s>` : ''}
                <strong>${moneyFmt(priceCents)}</strong>
              </p>
            </div>
          </a>
        `;
      }).join('');

      dropdown.innerHTML = `
        <div class="ame-predictive__list">${items}</div>
        <a class="ame-predictive__all" href="{{ routes.search_url }}?type=product&q=${encodeURIComponent(query)}">
          Ver todos os resultados para "${escapeHTML(query)}"
          <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
        </a>
      `;
      dropdown.hidden = false;
    }

    async function fetchPredictive(query) {
      const params = new URLSearchParams({
        q: query,
        'resources[type]': 'product',
        'resources[limit]': String(PREDICTIVE_LIMIT),
        'resources[options][unavailable_products]': 'last',
      });
      const res = await fetch(`/search/suggest.json?${params.toString()}`, {
        headers: { Accept: 'application/json' },
      });
      if (!res.ok) throw new Error('suggest fetch failed');
      const data = await res.json();
      return data?.resources?.results?.products || [];
    }

    let predictiveTimer = null;
    let predictiveAbort = null;

    function bindPredictive(input) {
      if (!input) return;
      const inOverlay = input.closest('[data-search-overlay]');
      const dropdown = inOverlay
        ? inOverlay.querySelector('[data-predictive-dropdown]')
        : document.querySelector('[data-predictive-dropdown][data-predictive-scope="desktop"]');
      if (!dropdown) return;

      input.addEventListener('input', () => {
        const query = input.value.trim();
        clearTimeout(predictiveTimer);
        predictiveAbort?.abort?.();

        if (query.length < 2) {
          dropdown.hidden = true;
          dropdown.innerHTML = '';
          return;
        }

        predictiveTimer = setTimeout(async () => {
          try {
            predictiveAbort = new AbortController();
            const products = await fetchPredictive(query);
            renderPredictiveDropdown(dropdown, query, products);
          } catch (err) {
            if (err.name !== 'AbortError') console.warn('[predictive]', err);
          }
        }, PREDICTIVE_DEBOUNCE_MS);
      });

      input.addEventListener('focus', () => {
        if (input.value.trim().length >= 2 && dropdown.innerHTML) {
          dropdown.hidden = false;
        }
      });
    }

    bindPredictive(searchInputInline);
    bindPredictive(searchInputMobile);

    document.addEventListener('click', (e) => {
      if (
        e.target.closest('[data-search-wrap]') ||
        e.target.closest('[data-search-overlay]') ||
        e.target.closest('[data-predictive-dropdown]') ||
        e.target.closest('[data-search-toggle]')
      ) return;
      document.querySelectorAll('[data-predictive-dropdown]').forEach(d => { d.hidden = true; });
    });

    /* ── Mobile menu ── */
    if (menuBtn && mobileNav) {
      menuBtn.addEventListener('click', () => {
        const open = mobileNav.classList.toggle('is-open');
        menuBtn.setAttribute('aria-expanded', open);
        mobileNav.setAttribute('aria-hidden', !open);
        menuIcon.textContent = open ? 'close' : 'menu';
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Cabeçalho",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Imagem do logo",
      "info": "Se vazio, exibe o nome da loja em texto."
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 60,
      "max": 280,
      "step": 10,
      "unit": "px",
      "label": "Largura do logo",
      "default": 140
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Altura máxima do logo",
      "default": 40
    },
    {
      "type": "header",
      "content": "Navegação"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu de navegação",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "Menu de conta do cliente",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
