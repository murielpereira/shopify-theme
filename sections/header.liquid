<header
  class="ame-header{% if settings.header_sticky %} ame-header--sticky{% endif %}"
  data-header
>
  <a href="{{ routes.root_url }}" class="ame-header__logo">
    {{ shop.name }}
  </a>

  <nav class="ame-header__nav" aria-label="Menu principal">
    {% for link in section.settings.menu.links %}
      <a
        href="{{ link.url }}"
        class="ame-header__nav-link{% if link.active %} ame-header__nav-link--active{% endif %}"
        {% if link.current %}aria-current="page"{% endif %}
      >
        {{ link.title }}
      </a>
    {% endfor %}
  </nav>

  <div class="ame-header__actions">
    <button class="ame-header__icon-btn" aria-label="Buscar" data-search-toggle>
      <span class="material-symbols-outlined">search</span>
    </button>

    {% if shop.customer_accounts_enabled %}
      <shopify-account menu="{{ section.settings.customer_account_menu }}">
        <button class="ame-header__icon-btn" aria-label="Minha conta">
          <span class="material-symbols-outlined">person</span>
        </button>
      </shopify-account>
    {% endif %}

    <a href="{{ routes.cart_url }}" class="ame-header__icon-btn ame-header__cart" aria-label="Carrinho ({{ cart.item_count }} itens)">
      <span class="material-symbols-outlined">shopping_bag</span>
      {%- if cart.item_count > 0 -%}
        <span class="ame-header__cart-count">{{ cart.item_count }}</span>
      {%- endif -%}
    </a>

    <button class="ame-header__icon-btn ame-header__mobile-menu-btn" aria-label="Menu" aria-expanded="false" data-mobile-menu-toggle>
      <span class="material-symbols-outlined" data-menu-icon>menu</span>
    </button>
  </div>
</header>

<nav class="ame-mobile-nav" id="mobile-nav" aria-hidden="true" data-mobile-nav>
  {% for link in section.settings.menu.links %}
    <a
      href="{{ link.url }}"
      class="ame-mobile-nav__link{% if link.active %} ame-mobile-nav__link--active{% endif %}"
    >
      {{ link.title }}
    </a>
  {% endfor %}
</nav>

{% stylesheet %}
  .ame-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--page-margin, 2rem);
    background: rgba(255, 248, 243, 0.72);
    backdrop-filter: blur(28px);
    -webkit-backdrop-filter: blur(28px);
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  .ame-header.is-scrolled {
    background: rgba(255, 248, 243, 0.92);
    box-shadow: 0 1px 0 rgba(32, 27, 20, 0.06);
  }

  /* Logo */
  .ame-header__logo {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 1.125rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-primary, #5a4742);
    text-decoration: none;
    white-space: nowrap;
  }

  /* Desktop nav */
  .ame-header__nav {
    display: none;
    gap: 2.5rem;
    align-items: center;
  }
  @media (min-width: 768px) {
    .ame-header__nav { display: flex; }
  }

  .ame-header__nav-link {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(90, 71, 66, 0.5);
    text-decoration: none;
    transition: color 0.25s ease, letter-spacing 0.3s ease;
  }
  .ame-header__nav-link:hover,
  .ame-header__nav-link--active {
    color: var(--color-primary, #5a4742);
    letter-spacing: 0.18em;
  }
  .ame-header__nav-link--active {
    border-bottom: 1px solid rgba(90, 71, 66, 0.3);
    padding-bottom: 2px;
  }

  /* Action icons */
  .ame-header__actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .ame-header__icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-primary, #5a4742);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: transform 0.25s ease;
    position: relative;
  }
  .ame-header__icon-btn:hover { transform: scale(1.1); }

  .ame-header__icon-btn .material-symbols-outlined {
    font-size: 1.375rem;
    font-variation-settings: 'wght' 250;
  }

  .ame-header__cart-count {
    position: absolute;
    top: -4px;
    right: -6px;
    width: 1rem;
    height: 1rem;
    background: var(--color-primary, #5a4742);
    color: var(--color-on-primary, #ffffff);
    font-size: 0.5625rem;
    font-weight: 700;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Mobile menu button — hide on desktop */
  .ame-header__mobile-menu-btn { display: flex; }
  @media (min-width: 768px) {
    .ame-header__mobile-menu-btn { display: none; }
  }

  /* Mobile nav drawer */
  .ame-mobile-nav {
    position: fixed;
    top: 5rem;
    left: 0;
    right: 0;
    z-index: 99;
    background: rgba(255, 248, 243, 0.96);
    backdrop-filter: blur(28px);
    -webkit-backdrop-filter: blur(28px);
    display: flex;
    flex-direction: column;
    padding: 1.5rem var(--page-margin, 2rem) 2rem;
    gap: 1.5rem;
    transform: translateY(-100%);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.4s cubic-bezier(0.22,1,0.36,1), opacity 0.3s ease;
  }
  .ame-mobile-nav.is-open {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }
  @media (min-width: 768px) {
    .ame-mobile-nav { display: none; }
  }

  .ame-mobile-nav__link {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 1.25rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-on-background, #201b14);
    text-decoration: none;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(210, 195, 192, 0.2);
    transition: color 0.2s ease;
  }
  .ame-mobile-nav__link:hover,
  .ame-mobile-nav__link--active { color: var(--color-primary, #5a4742); }

  /* Body offset so content doesn't hide under fixed header */
  body { padding-top: 5rem; }
{% endstylesheet %}

<script>
  (() => {
    const header     = document.querySelector('[data-header]');
    const mobileNav  = document.querySelector('[data-mobile-nav]');
    const menuBtn    = document.querySelector('[data-mobile-menu-toggle]');
    const menuIcon   = document.querySelector('[data-menu-icon]');

    /* Scroll shadow */
    const onScroll = () => {
      header.classList.toggle('is-scrolled', window.scrollY > 20);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    /* Mobile menu toggle */
    if (menuBtn && mobileNav) {
      menuBtn.addEventListener('click', () => {
        const open = mobileNav.classList.toggle('is-open');
        menuBtn.setAttribute('aria-expanded', open);
        mobileNav.setAttribute('aria-hidden', !open);
        menuIcon.textContent = open ? 'close' : 'menu';
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Cabeçalho",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu de navegação",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "Menu de conta do cliente",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
