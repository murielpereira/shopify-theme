{% comment %} Âme — Barra de diferenciais da loja {% endcomment %}

<div class="ame-ad-bar full-width">
  <div class="ame-ad-bar__track" data-ad-bar-track>
    {%- for block in section.blocks -%}
      {%- if block.settings.label != blank -%}
        <div class="ame-ad-bar__item" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}
            <a
              href="{{ block.settings.link }}"
              class="ame-ad-bar__item-inner"
              target="_blank"
              rel="noopener noreferrer"
            >
          {%- else -%}
            <div class="ame-ad-bar__item-inner">
          {%- endif -%}

          <span class="ame-ad-bar__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'warranty' -%}
                <svg viewBox="0 -0.5 25 25" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M10.4608 1.50732C11.2607 0.539132 12.7446 0.539132 13.5445 1.50732L14.7445 2.95979C15.1677 3.472 15.8176 3.74061 16.4789 3.67664L18.3571 3.49495C19.6102 3.37372 20.6624 4.42666 20.5402 5.67974L20.3597 7.53129C20.2949 8.1958 20.566 8.84883 21.0823 9.2721L22.5232 10.4533C23.4993 11.2534 23.4993 12.7466 22.5232 13.5467L21.0823 14.7279C20.566 15.1512 20.2949 15.8042 20.3597 16.4687L20.5402 18.3203C20.6624 19.5733 19.6102 20.6263 18.3571 20.505L16.4789 20.3234C15.8176 20.2594 15.1677 20.528 14.7445 21.0402L13.5445 22.4927C12.7446 23.4609 11.2607 23.4609 10.4608 22.4927L9.26079 21.0402C8.83761 20.528 8.18769 20.2594 7.52637 20.3234L5.64824 20.505C4.39507 20.6263 3.34293 19.5733 3.4651 18.3203L3.64562 16.4687C3.71041 15.8042 3.43933 15.1512 2.92298 14.7279L1.48208 13.5467C0.505968 12.7466 0.505968 11.2534 1.48208 10.4533L2.92298 9.2721C3.43933 8.84883 3.71041 8.1958 3.64562 7.53129L3.4651 5.67974C3.34293 4.42666 4.39507 3.37372 5.64824 3.49495L7.52637 3.67664C8.18769 3.74061 8.83761 3.472 9.26079 2.95979L10.4608 1.50732Z" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M8.12549 12.7725L10.4136 15.0516C10.8437 15.48 11.5531 15.4296 11.9182 14.9446L15.8801 9.68274" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>

              {%- when 'leather' -%}
                <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <ellipse cx="50" cy="38" rx="28" ry="22" stroke="currentColor" stroke-width="5" fill="none"/>
                  <path d="M22 38 Q18 65 30 75 Q50 88 70 75 Q82 65 78 38" stroke="currentColor" stroke-width="5" fill="none" stroke-linecap="round"/>
                  <path d="M38 38 Q42 48 50 50 Q58 48 62 38" stroke="currentColor" stroke-width="4" fill="none" stroke-linecap="round"/>
                  <circle cx="50" cy="32" r="4" fill="currentColor" opacity="0.5"/>
                </svg>

              {%- when 'handmade' -%}
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M9 11V6a1 1 0 0 1 2 0v5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <path d="M11 10V5a1 1 0 0 1 2 0v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <path d="M13 10.5V7a1 1 0 0 1 2 0v4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <path d="M15 11V9a1 1 0 0 1 2 0v4c0 3.314-2.686 6-6 6a6 6 0 0 1-6-6v-2.5a1 1 0 0 1 2 0V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>

              {%- when 'shipping' -%}
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <!-- Adicionei um translate para descer o desenho em 4 unidades -->
                  <g transform="translate(0, 4)">
                    <path d="M1 3.5A1.5 1.5 0 0 1 2.5 2h9A1.5 1.5 0 0 1 13 3.5V5h1.02a1.5 1.5 0 0 1 1.17.563l1.481 1.85a1.5 1.5 0 0 1 .329.938V11.5a1.5 1.5 0 0 1-1.5 1.5H15a2 2 0 1 1-4 0H6a2 2 0 1 1-4-.085A1.5 1.5 0 0 1 1 11.5Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" fill="none"></path>
                    <circle cx="4.5" cy="13.5" r="1" fill="currentColor"></circle>
                    <circle cx="12.5" cy="13.5" r="1" fill="currentColor"></circle>
                  </g>
                </svg>

              {%- when 'installments' -%}
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M2 9h20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <path d="M6 13h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>

              {%- when 'whatsapp' -%}
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M20.472 3.528A11.955 11.955 0 0 0 12 0C5.373 0 0 5.373 0 12c0 2.115.553 4.17 1.605 5.973L0 24l6.195-1.625A11.944 11.944 0 0 0 12 24c6.627 0 12-5.373 12-12a11.955 11.955 0 0 0-3.528-8.472Z" fill="currentColor" opacity="0.15"/>
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.472-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a13.27 13.27 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347Z" fill="currentColor"/>
                </svg>

              {%- when 'star' -%}
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M12 2l2.939 6.116L22 9.27l-5.5 5.18 1.38 7.55L12 18.364l-5.88 3.636 1.38-7.55L2 9.27l7.061-1.154L12 2Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                </svg>

              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M12 8v4l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
            {%- endcase -%}
          </span>

          <div class="ame-ad-bar__text">
            <span class="ame-ad-bar__label">{{ block.settings.label }}</span>
            {%- if block.settings.sublabel != blank -%}
              <span class="ame-ad-bar__sublabel">{{ block.settings.sublabel }}</span>
            {%- endif -%}
          </div>

          {%- if block.settings.link != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .ame-ad-bar {
    width: 100%;
    background: var(--color-surface-container, #f8ece0);
    overflow: hidden;
    border-bottom: 1px solid rgba(210, 195, 192, 0.18);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ame-ad-bar__track {
    display: flex;
    align-items: stretch;
    width: 85%;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .ame-ad-bar__track::-webkit-scrollbar {
    display: none;
  }

  /* Desktop: distribuir igualmente sem scroll */
  @media (min-width: 768px) {
    .ame-ad-bar__track {
      overflow-x: visible;
      justify-content: center;
    }
  }

  .ame-ad-bar__item {
    flex: 0 0 auto;
    position: relative;
  }
  @media (min-width: 768px) {
    .ame-ad-bar__item {
      flex: 1 1 0;
    }
    /* Divisor vertical entre itens */
    .ame-ad-bar__item + .ame-ad-bar__item::before {
      content: '';
      position: absolute;
      left: 0;
      top: 20%;
      height: 60%;
      width: 1px;
      background: rgba(210, 195, 192, 0.35);
    }
  }

  .ame-ad-bar__item-inner {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 1.125rem 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.25s ease;
    justify-content: center;
    height: 100%;
  }
  a.ame-ad-bar__item-inner:hover {
    background: rgba(210, 195, 192, 0.18);
  }

  .ame-ad-bar__icon {
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
    color: var(--color-primary-container, #735e59);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.85;
  }
  .ame-ad-bar__icon svg {
    width: 100%;
    height: 100%;
  }

  .ame-ad-bar__text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    white-space: nowrap;
  }

  .ame-ad-bar__label {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-on-background, #201b14);
    line-height: 1.2;
  }

  .ame-ad-bar__sublabel {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-on-surface-variant, #4f4442);
    opacity: 0.65;
    line-height: 1.3;
  }

  @media (max-width: 767px) {
    .ame-ad-bar__item-inner {
      padding: 1rem 1.25rem;
      gap: 0.625rem;
    }
    .ame-ad-bar__label {
      font-size: 0.6875rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Barra de Diferenciais",
  "tag": "section",
  "settings": [],
  "blocks": [
    {
      "type": "item",
      "name": "Diferencial",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Ícone",
          "options": [
            { "value": "warranty", "label": "Garantia (selo)" },
            { "value": "leather", "label": "Couro / Material" },
            { "value": "handmade", "label": "Feito à mão" },
            { "value": "shipping", "label": "Entrega / Frete" },
            { "value": "installments", "label": "Parcelamento / Cartão" },
            { "value": "whatsapp", "label": "WhatsApp / Contato" },
            { "value": "star", "label": "Estrela / Qualidade" }
          ],
          "default": "warranty"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Título",
          "default": "Garantia"
        },
        {
          "type": "text",
          "id": "sublabel",
          "label": "Subtítulo",
          "default": "de 6 meses"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (opcional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barra de Diferenciais",
      "blocks": [
        { "type": "item", "settings": { "icon": "warranty", "label": "Garantia", "sublabel": "de 6 meses" } },
        { "type": "item", "settings": { "icon": "leather", "label": "Couro", "sublabel": "Legítimo" } },
        { "type": "item", "settings": { "icon": "handmade", "label": "Feito a mão", "sublabel": "com carinho" } },
        { "type": "item", "settings": { "icon": "shipping", "label": "Entrega", "sublabel": "para todo o Brasil" } },
        {
          "type": "item",
          "settings": { "icon": "installments", "label": "Parcelamento", "sublabel": "até 6x sem juros" }
        },
        { "type": "item", "settings": { "icon": "whatsapp", "label": "Dúvidas?", "sublabel": "Fale com a gente" } }
      ]
    }
  ],
  "disabled_on": { "groups": ["header", "footer"] }
}
{% endschema %}
