{% comment %} Âme — Página de Produto {% endcomment %}

{%- liquid
  assign cv = product.selected_or_first_available_variant
  assign media_size = product.media.size
-%}

<!-- Breadcrumb -->
<nav class="pdp-breadcrumb full-width" aria-label="Navegação">
  <a href="{{ routes.root_url }}">Início</a>
  <span aria-hidden="true">/</span>
  {%- if collection -%}
    <a href="{{ collection.url }}">{{ collection.title }}</a>
    <span aria-hidden="true">/</span>
  {%- endif -%}
  <span aria-current="page">{{ product.title }}</span>
</nav>

<div class="pdp full-width">
  <!-- ── Coluna esquerda: galeria ── -->
  <div class="pdp__gallery">
    <!-- Imagem principal -->
    <div class="pdp__main-img-wrap">
      {%- if media_size > 0 -%}
        <div class="pdp__track" id="pdp-track">
          {%- for media in product.media -%}
            <div class="pdp__slide" data-media-id="{{ media.id }}">
              {%- if media.media_type == 'image' -%}
                {{-
                  media
                  | image_url: width: 1200
                  | image_tag: loading: 'lazy', class: 'pdp__slide-img', alt: media.alt
                  | default: product.title
                  | escape
                -}}
              {%- elsif media.media_type == 'video' -%}
                {{ media | video_tag: class: 'pdp__slide-img', autoplay: false, loop: true, muted: true }}
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
        <!-- contador -->
        <div class="pdp__counter" aria-live="polite"><span id="pdp-current">1</span> / {{ media_size }}</div>
        <!-- botões de navegação -->
        <button class="pdp__nav pdp__nav--prev" id="pdp-prev" aria-label="Anterior">
          <span class="material-symbols-outlined">arrow_back_ios</span>
        </button>
        <button class="pdp__nav pdp__nav--next" id="pdp-next" aria-label="Próximo">
          <span class="material-symbols-outlined">arrow_forward_ios</span>
        </button>
      {%- else -%}
        <div class="pdp__track" id="pdp-track">
          <div class="pdp__slide">
            {{ 'product-1' | placeholder_svg_tag: 'pdp__slide-img pdp__slide-img--placeholder' }}
          </div>
        </div>
      {%- endif -%}

      {%- liquid
        assign img_compare = cv.compare_at_price | default: 0
        if img_compare == 0
          assign img_compare = product.compare_at_price_max | default: 0
        endif
        assign pdp_img_discount = 0
        if img_compare > cv.price
          assign pdp_img_discount = img_compare | minus: cv.price | times: 100 | divided_by: img_compare | round
        elsif settings.auto_discount_enabled and settings.auto_discount_percent > 0
          assign pdp_img_discount = settings.auto_discount_percent
        endif
      -%}
      <div id="pdp-img-badge-wrap">
        {%- if pdp_img_discount > 0 -%}
          <span class="pdp__img-discount-badge" aria-label="{{ pdp_img_discount }}% de desconto">
            {{ pdp_img_discount }}% OFF
          </span>
        {%- endif -%}
      </div>
    </div>

    <!-- Thumbnails em linha horizontal com scroll -->
    {%- if media_size > 1 -%}
      <div class="pdp__thumbs-wrap">
        <div class="pdp__thumbs-fade pdp__thumbs-fade--top" aria-hidden="true"></div>
        <div class="pdp__thumbs" role="list">
          {%- for media in product.media -%}
            <button
              class="pdp__thumb{% if forloop.first %} pdp__thumb--active{% endif %}"
              data-index="{{ forloop.index0 }}"
              aria-label="Imagem {{ forloop.index }}"
              role="listitem"
              type="button"
            >
              {{-
                media.preview_image
                | image_url: width: 160
                | image_tag: loading: 'lazy', alt: '', class: 'pdp__thumb-img'
              -}}
            </button>
          {%- endfor -%}
        </div>
        <div class="pdp__thumbs-fade pdp__thumbs-fade--bottom" aria-hidden="true"></div>
      </div>
    {%- endif -%}
  </div>

  <!-- ── Coluna direita: informações ── -->
  <div class="pdp__info">
    <!-- Badge de coleção / heritage -->
    {%- liquid
      assign show_meta = false
      for tag in product.tags
        if tag == 'heritage' or tag == 'Heritage'
          assign show_meta = true
        endif
      endfor
      if product.available == false
        assign show_meta = true
      endif
    -%}
    {%- if show_meta -%}
      <div class="pdp__meta">
        {%- for tag in product.tags -%}
          {%- if tag == 'heritage' or tag == 'Heritage' -%}
            <span class="ame-chip">Heritage Series</span>
          {%- endif -%}
        {%- endfor -%}
        {%- if product.available == false -%}
          <span class="ame-chip">Esgotado</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- Título -->
    <h1 class="pdp__title">{{ product.title }}</h1>

    <!-- Rating (placeholder — substituir por app) -->
    <div class="pdp__rating" aria-label="4.8 de 5 estrelas">
      <div class="pdp__stars" aria-hidden="true">
        <span
          class="material-symbols-outlined"
          style="font-variation-settings:'FILL' 1;font-size:0.9rem;color:var(--color-primary);"
          >star</span
        >
        <span
          class="material-symbols-outlined"
          style="font-variation-settings:'FILL' 1;font-size:0.9rem;color:var(--color-primary);"
          >star</span
        >
        <span
          class="material-symbols-outlined"
          style="font-variation-settings:'FILL' 1;font-size:0.9rem;color:var(--color-primary);"
          >star</span
        >
        <span
          class="material-symbols-outlined"
          style="font-variation-settings:'FILL' 1;font-size:0.9rem;color:var(--color-primary);"
          >star</span
        >
        <span
          class="material-symbols-outlined"
          style="font-variation-settings:'FILL' 0;font-size:0.9rem;color:var(--color-outline-variant);"
          >star</span
        >
      </div>
      <span class="pdp__rating-text">4.8 · 32 avaliações</span>
    </div>

    <!-- ── Bloco de preços ── -->
    {%- liquid
      assign cv_compare = cv.compare_at_price | default: 0
      if cv_compare == 0
        assign cv_compare = product.compare_at_price_max | default: 0
      endif
      assign has_compare = false
      assign discount_pct = 0
      if cv_compare > cv.price
        assign has_compare = true
        assign discount_pct = cv_compare | minus: cv.price | times: 100 | divided_by: cv_compare
      endif

      assign effective_price = cv.price
      assign displayed_compare = cv_compare
      if has_compare == false and settings.auto_discount_enabled and settings.auto_discount_percent > 0
        assign has_compare = true
        assign discount_pct = settings.auto_discount_percent
        assign displayed_compare = cv.price
        assign disc_cents = cv.price | times: discount_pct | divided_by: 100
        assign effective_price = cv.price | minus: disc_cents
      endif

      assign pix_pct = settings.pix_discount | default: 5
      assign pix_price_cents = effective_price | times: pix_pct | divided_by: 100
      assign pix_price_cents = effective_price | minus: pix_price_cents
      assign inst_count = settings.installments_count | default: 3
      assign inst_value = effective_price | divided_by: inst_count
    -%}

    <div class="pdp__price-block" id="pdp-price-block">
      <!-- Linha "De:" riscado -->
      {%- if has_compare -%}
        <div class="pdp__price-compare-row">
          <s class="pdp__price-compare">De: {{ displayed_compare | money }}</s>
        </div>
      {%- endif -%}

      <!-- Preço no cartão + badge de desconto -->
      <div class="pdp__price-card-row">
        <span class="pdp__price-label">a partir de</span>
        <strong class="pdp__price-main">{{ effective_price | money }}</strong>
        <span class="pdp__price-label">no cartão</span>
        {%- if has_compare -%}
          <span class="pdp__discount-badge">−{{ discount_pct }}% OFF</span>
        {%- endif -%}
      </div>

      <!-- Preço no Pix -->
      {%- if settings.show_pix != false -%}
        <div class="pdp__price-pix-row">
          <span class="pdp__price-label">ou</span>
          <strong class="pdp__price-pix" id="pdp-price-pix">{{ pix_price_cents | money }}</strong>
          <span class="pdp__price-label">com Pix</span>
        </div>
      {%- endif -%}

      <!-- Parcelamento -->
      {%- if settings.show_installments != false and inst_count > 1 -%}
        <p class="pdp__installments">
          Até <strong>{{ inst_count }}x</strong> de <strong id="pdp-inst-value">{{ inst_value | money }}</strong> sem
          juros
          {%- if settings.show_installments_link != false -%}
            <a href="#" class="pdp__installments-link">Ver mais detalhes</a>
          {%- endif -%}
        </p>
      {%- endif -%}

      <!-- Cashback -->
      <div id="pdp-cashback-wrap">
        {%- render 'cashback', cashback_price: effective_price, cashback_mode: 'pdp' -%}
      </div>
    </div>

    <!-- ── Descrição curta ── -->
    {%- if product.description != blank -%}
      <div class="pdp__desc">{{ product.description }}</div>
    {%- endif -%}

    <!-- ── Formulário de produto ── -->
    {%- form 'product', product, id: 'pdp-form', novalidate: true -%}
      <input type="hidden" name="id" value="{{ cv.id }}" id="pdp-variant-id">

      <!-- Opções (Cor, Tamanho...) — renderizadas sob demanda via Section Rendering API -->
      <div id="pdp-options-wrap" data-section-id="{{ section.id }}">
        {%- for option in product.options_with_values -%}
          {%- liquid
            assign is_color = false
            if option.name == 'Color' or option.name == 'Cor' or option.name == 'Acabamento'
              assign is_color = true
            endif
          -%}

          <div class="pdp__option">
            <div class="pdp__option-header">
              <span class="pdp__option-label">{{ option.name }}</span>
              <span class="pdp__option-value" id="pdp-opt-val-{{ forloop.index }}">{{ option.selected_value }}</span>
            </div>

            {%- if is_color -%}
              <!-- Grade de swatches por imagem (6 colunas no mobile) -->
              <div class="pdp__swatches" data-option-index="{{ forloop.index0 }}">
                {%- for option_value in option.values -%}
                  {%- liquid
                    assign sw_variant = option_value.variant
                    assign sw_img = ''
                    assign sw_media_id = ''
                    if sw_variant.featured_media != blank
                      assign sw_img = sw_variant.featured_media.preview_image | image_url: width: 120
                      assign sw_media_id = sw_variant.featured_media.id
                    elsif sw_variant.featured_image != blank
                      assign sw_img = sw_variant.featured_image | image_url: width: 120
                      assign sw_media_id = sw_variant.featured_image.id
                    endif
                  -%}
                  <button
                    type="button"
                    class="pdp__swatch{% if option_value.selected %} pdp__swatch--active{% endif %}{% unless option_value.available %} pdp__swatch--disabled{% endunless %}"
                    data-value="{{ option_value | escape }}"
                    data-option-value-id="{{ option_value.id }}"
                    aria-label="{{ option_value }}"
                    title="{{ option_value }}"
                    {% if sw_media_id != '' %}
                      data-media-id="{{ sw_media_id }}"
                    {% endif %}
                    {% unless option_value.available %}
                      aria-disabled="true"
                    {% endunless %}
                  >
                    {%- if sw_img != '' -%}
                      <img
                        src="{{ sw_img }}"
                        alt="{{ option_value | escape }}"
                        class="pdp__swatch-img"
                        loading="lazy"
                        width="120"
                        height="120"
                      >
                    {%- else -%}
                      <span
                        class="pdp__swatch-color"
                        style="background:var(--swatch-{{ option_value | downcase | replace: ' ', '-' }},var(--color-surface-container,#f8ece0));"
                      ></span>
                    {%- endif -%}
                  </button>
                {%- endfor -%}
              </div>
            {%- else -%}
              <!-- Botões de tamanho -->
              <div class="pdp__sizes" data-option-index="{{ forloop.index0 }}">
                {%- for option_value in option.values -%}
                  <button
                    type="button"
                    class="pdp__size-btn{% if option_value.selected %} pdp__size-btn--active{% endif %}{% unless option_value.available %} pdp__size-btn--disabled{% endunless %}"
                    data-value="{{ option_value | escape }}"
                    data-option-value-id="{{ option_value.id }}"
                    {% unless option_value.available %}
                      aria-disabled="true"
                    {% endunless %}
                  >
                    {{ option_value }}
                  </button>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      {%- render 'pingente-customization', product: product -%}

      <!-- ── Campos Personalizados ── -->
      {%- for cf_tag_item in product.tags -%}
        {%- for cf_i in (1..10) -%}
          {%- liquid
            assign cf_en_key = 'custom_field_' | append: cf_i | append: '_enable'
            assign cf_tag_key = 'custom_field_' | append: cf_i | append: '_tag'
            assign cf_enabled = settings[cf_en_key]
            assign cf_cfg_tag = settings[cf_tag_key]
          -%}
          {%- if cf_enabled and cf_cfg_tag == cf_tag_item -%}
            {%- liquid
              assign cf_nm_key = 'custom_field_' | append: cf_i | append: '_name'
              assign cf_tt_key = 'custom_field_' | append: cf_i | append: '_title'
              assign cf_ph_key = 'custom_field_' | append: cf_i | append: '_placeholder'
              assign cf_hl_key = 'custom_field_' | append: cf_i | append: '_helper'
              assign cf_lm_key = 'custom_field_' | append: cf_i | append: '_limiter'
              assign cf_tp_key = 'custom_field_' | append: cf_i | append: '_type'
              assign cf_op_key = 'custom_field_' | append: cf_i | append: '_options'
              assign cf_rq_key = 'custom_field_' | append: cf_i | append: '_required'
              assign cf_name = settings[cf_nm_key]
              assign cf_title = settings[cf_tt_key]
              assign cf_placeholder = settings[cf_ph_key] | default: cf_title
              assign cf_helper = settings[cf_hl_key]
              assign cf_limiter = settings[cf_lm_key]
              assign cf_type = settings[cf_tp_key]
              assign cf_options = settings[cf_op_key]
              assign cf_req = settings[cf_rq_key]
            -%}
            <div class="pdp__custom-field">
              {%- if cf_type == 'text' or cf_type == 'date' -%}
                <label class="pdp__custom-field__label" for="cf-{{ cf_name | handle }}">
                  {{- cf_title -}}
                  {%- if cf_req -%}
                    <span class="pdp__custom-field__req" aria-hidden="true"> *</span>
                  {%- endif -%}
                </label>
                <input
                  id="cf-{{ cf_name | handle }}"
                  type="text"
                  name="properties[{{ cf_name }}]"
                  placeholder="{{ cf_placeholder }}"
                  class="pdp__custom-field__input{% if cf_type == 'date' %} pdp__custom-field__input--date{% endif %}"
                  {%- if cf_req %}
                    data-cf-required="true"
                  {% endif %}
                  {%- if cf_limiter != blank %}
                    maxlength="{{ cf_limiter }}"
                  {% endif %}
                >
                {%- if cf_helper != blank -%}
                  <p class="pdp__custom-field__helper">{{ cf_helper }}</p>
                {%- endif -%}
                {%- if cf_req -%}
                  <p class="pdp__custom-field__error-msg">Este campo é obrigatório.</p>
                {%- endif -%}
              {%- elsif cf_type == 'long_text' -%}
                <label class="pdp__custom-field__label" for="cf-{{ cf_name | handle }}">
                  {{- cf_title -}}
                  {%- if cf_req -%}
                    <span class="pdp__custom-field__req" aria-hidden="true"> *</span>
                  {%- endif -%}
                </label>
                <textarea
                  id="cf-{{ cf_name | handle }}"
                  name="properties[{{ cf_name }}]"
                  placeholder="{{ cf_placeholder }}"
                  class="pdp__custom-field__textarea"
                  {%- if cf_req %}
                    data-cf-required="true"
                  {% endif %}
                  {%- if cf_limiter != blank %}
                    maxlength="{{ cf_limiter }}"
                  {% endif %}
                  rows="3"
                ></textarea>
                {%- if cf_helper != blank -%}
                  <p class="pdp__custom-field__helper">{{ cf_helper }}</p>
                {%- endif -%}
                {%- if cf_req -%}
                  <p class="pdp__custom-field__error-msg">Este campo é obrigatório.</p>
                {%- endif -%}
              {%- elsif cf_type == 'radio' -%}
                <div class="pdp__custom-field__label">
                  {{- cf_title -}}
                  {%- if cf_req -%}
                    <span class="pdp__custom-field__req" aria-hidden="true"> *</span>
                  {%- endif -%}
                </div>
                <div class="pdp__custom-field__radio-group">
                  {%- assign cf_opts = cf_options | split: ',' -%}
                  {%- for cf_opt in cf_opts -%}
                    {%- assign opt_val = cf_opt | strip -%}
                    <button type="button" class="pdp__custom-field__radio-btn" data-value="{{ opt_val | escape }}">
                      {{- opt_val -}}
                    </button>
                  {%- endfor -%}
                </div>
                <input
                  type="hidden"
                  name="properties[{{ cf_name }}]"
                  id="cf-hidden-{{ cf_name | handle }}"
                  class="pdp__custom-field__radio-val"
                  {%- if cf_req %}
                    data-cf-required="true"
                  {% endif %}
                >
                {%- if cf_helper != blank -%}
                  <p class="pdp__custom-field__helper">{{ cf_helper }}</p>
                {%- endif -%}
                {%- if cf_req -%}
                  <p class="pdp__custom-field__error-msg">Selecione uma opção.</p>
                {%- endif -%}
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endfor -%}

      <!-- Quantidade -->
      <div class="pdp__qty">
        <span class="pdp__option-label">Quantidade</span>
        <div class="pdp__qty-ctrl">
          <button type="button" class="pdp__qty-btn" id="pdp-qty-minus" aria-label="Diminuir">−</button>
          <input
            type="number"
            name="quantity"
            id="pdp-qty"
            value="1"
            min="1"
            class="pdp__qty-input"
            aria-label="Quantidade"
          >
          <button type="button" class="pdp__qty-btn" id="pdp-qty-plus" aria-label="Aumentar">+</button>
        </div>
      </div>

      <!-- CTAs -->
      <div class="pdp__ctas">
        <div id="pdp-add-btn-wrap" style="display:contents">
          <button
            type="submit"
            class="ame-cta pdp__add-btn"
            id="pdp-add-btn"
            {%- unless cv.available %}
              disabled
            {%- endunless %}
          >
            {%- if cv.available -%}
              Adicionar ao Carrinho
              <span class="material-symbols-outlined" style="font-size:1rem;">shopping_bag</span>
            {%- else -%}
              Esgotado
            {%- endif -%}
          </button>
        </div>

        <button type="button" class="pdp__wishlist-btn" aria-label="Favoritar" id="pdp-wishlist" aria-pressed="false">
          <span class="material-symbols-outlined" style="font-size:1.25rem;font-variation-settings:'FILL' 0;"
            >favorite</span
          >
        </button>
      </div>
    {%- endform -%}
  </div>
  <!-- /pdp__info -->
</div>
<!-- /pdp -->

<!-- ── Acordeões de detalhes ── -->
<div class="pdp-accordions full-width">
  {%- for block in section.blocks -%}
    {%- if block.type == 'accordion' -%}
      <div class="ame-accordion" {{ block.shopify_attributes }}>
        <button class="ame-accordion__btn" type="button" aria-expanded="false" aria-controls="pdp-accordion-content-{{ section.id }}-{{ forloop.index }}">
          <span>{{ block.settings.title }}</span>
          <span
            class="material-symbols-outlined ame-accordion__icon"
            style="font-variation-settings:'wght' 300;"
            aria-hidden="true"
            >add</span
          >
        </button>
        <div id="pdp-accordion-content-{{ section.id }}-{{ forloop.index }}" class="ame-accordion__content" hidden>
          <div class="ame-accordion__body">{{ block.settings.body }}</div>
        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}

  {%- if section.blocks.size == 0 and product.description != blank -%}
    <div class="ame-accordion">
      <button class="ame-accordion__btn" type="button" aria-expanded="false" aria-controls="pdp-accordion-content-{{ section.id }}-default">
        <span>Detalhes do Produto</span>
        <span
          class="material-symbols-outlined ame-accordion__icon"
          style="font-variation-settings:'wght' 300;"
          aria-hidden="true"
          >add</span
        >
      </button>
      <div id="pdp-accordion-content-{{ section.id }}-default" class="ame-accordion__content" hidden>
        <div class="ame-accordion__body">{{ product.description }}</div>
      </div>
    </div>
  {%- endif -%}
</div>

<!-- ── Produtos relacionados ── -->
{%- if section.settings.show_related and recommendations.performed and recommendations.products_count > 0 -%}
  <div class="ame-pdp-related full-width">
    <div class="ame-pdp-related__header ame-reveal">
      <p class="ame-label-sm">Complete o Look</p>
      <h2 class="ame-pdp-related__title">Você Também Vai Amar.</h2>
    </div>
    <div class="ame-pdp-related__grid">
      {% comment %}
        ⚡ Bolt: Replace snippet render inside for-loop with `render ... for` syntax.
        💡 What: Pre-slices the recommendations to 4 products and uses the `render 'product-card' for array` tag instead of manually looping.
        🎯 Why: Liquid processes a `for` loop with a `render` inside by parsing and scoping the snippet per iteration (N+1 overhead).
        📊 Impact: Eliminates N+1 rendering overhead, improving product page rendering time.
        🔬 Measurement: Profile the Server Response time on product pages.
      {% endcomment %}
      {%- assign limited_recs = recommendations.products | slice: 0, 4 -%}
      {%- render 'product-card' for limited_recs as card_product -%}
    </div>
  </div>
{%- endif -%}

<script>
  (() => {
    /* ── Carousel ── */
    const track   = document.getElementById('pdp-track');
    const thumbs     = document.querySelectorAll('.pdp__thumb');
    const counter    = document.getElementById('pdp-current');
    const thumbsEl   = document.querySelector('.pdp__thumbs');
    const thumbsWrap = document.querySelector('.pdp__thumbs-wrap');
    let cur = 0;
    const total = thumbs.length || 1;

    function updateThumbIndicators() {
      if (!thumbsWrap || !thumbsEl) return;
      thumbsWrap.classList.toggle('can-scroll-up',   thumbsEl.scrollLeft > 4);
      thumbsWrap.classList.toggle('can-scroll-down',
        thumbsEl.scrollLeft < thumbsEl.scrollWidth - thumbsEl.clientWidth - 4);
    }

    function scrollThumbIntoView(thumb) {
      if (!thumbsEl || !thumb) return;
      const relLeft  = thumb.offsetLeft - thumbsEl.offsetLeft;
      const relRight = relLeft + thumb.offsetWidth;
      if (relRight > thumbsEl.scrollLeft + thumbsEl.clientWidth) {
        thumbsEl.scrollTo({ left: relRight - thumbsEl.clientWidth, behavior: 'smooth' });
      } else if (relLeft < thumbsEl.scrollLeft) {
        thumbsEl.scrollTo({ left: relLeft, behavior: 'smooth' });
      }
    }

    function goTo(i) {
      cur = Math.max(0, Math.min(i, total - 1));
      track.style.transform = `translateX(-${cur * 100}%)`;
      thumbs.forEach((t, idx) => t.classList.toggle('pdp__thumb--active', idx === cur));
      if (counter) counter.textContent = cur + 1;
      scrollThumbIntoView(thumbs[cur]);
    }

    if (thumbsEl) {
      thumbsEl.addEventListener('scroll', updateThumbIndicators, { passive: true });
      updateThumbIndicators();
    }

    document.getElementById('pdp-prev')?.addEventListener('click', () => goTo(cur - 1));
    document.getElementById('pdp-next')?.addEventListener('click', () => goTo(cur + 1));
    thumbs.forEach(t => t.addEventListener('click', () => goTo(+t.dataset.index)));

    /* swipe */
    let sx = 0;
    track?.addEventListener('touchstart', e => { sx = e.touches[0].clientX; }, { passive: true });
    track?.addEventListener('touchend',   e => {
      const dx = sx - e.changedTouches[0].clientX;
      if (Math.abs(dx) > 40) goTo(dx > 0 ? cur + 1 : cur - 1);
    });

    /* ── Quantidade ── */
    const qtyInput = document.getElementById('pdp-qty');
    document.getElementById('pdp-qty-minus')?.addEventListener('click', () => {
      if (qtyInput && +qtyInput.value > 1) qtyInput.value = +qtyInput.value - 1;
    });
    document.getElementById('pdp-qty-plus')?.addEventListener('click', () => {
      if (qtyInput) qtyInput.value = +qtyInput.value + 1;
    });

    /* ── Variantes (Section Rendering API — suporta >250 variantes) ── */
    const SECTION_ID = {{ section.id | json }};
    const PRODUCT_URL = {{ product.url | json }};

    function navigateGalleryToMedia(mediaId) {
      if (!mediaId || !track) return;
      const targetSlide = track.querySelector(`[data-media-id="${mediaId}"]`);
      if (!targetSlide) return;
      const slides = Array.from(track.querySelectorAll('.pdp__slide'));
      const idx = slides.indexOf(targetSlide);
      if (idx >= 0) goTo(idx);
    }

    async function refreshVariantSection() {
      const optionValueIds = [];
      document.querySelectorAll('#pdp-options-wrap [data-option-index]').forEach(g => {
        const active = g.querySelector('.pdp__swatch--active, .pdp__size-btn--active');
        if (active?.dataset.optionValueId) optionValueIds.push(active.dataset.optionValueId);
      });
      if (optionValueIds.length === 0) return;

      const params = new URLSearchParams({
        section_id: SECTION_ID,
        option_values: optionValueIds.join(','),
      });
      try {
        const res = await fetch(`${PRODUCT_URL}?${params.toString()}`, { headers: { Accept: 'text/html' } });
        if (!res.ok) return;
        const html = await res.text();
        const doc = new DOMParser().parseFromString(html, 'text/html');

        ['pdp-options-wrap', 'pdp-price-block', 'pdp-add-btn-wrap', 'pdp-img-badge-wrap'].forEach(id => {
          const fresh = doc.getElementById(id);
          const current = document.getElementById(id);
          if (fresh && current) current.replaceWith(fresh);
        });

        const freshVariantInput = doc.getElementById('pdp-variant-id');
        const currentVariantInput = document.getElementById('pdp-variant-id');
        if (freshVariantInput && currentVariantInput) currentVariantInput.value = freshVariantInput.value;

        bindOptionClicks();

        const newActive = document.querySelector('#pdp-options-wrap .pdp__swatch--active');
        if (newActive?.dataset.mediaId) navigateGalleryToMedia(newActive.dataset.mediaId);

        document.dispatchEvent(new CustomEvent('pdp:variant-changed'));
      } catch (err) {
        console.warn('[pdp] refreshVariantSection failed', err);
      }
    }

    function bindOptionClicks() {
      document.querySelectorAll('#pdp-options-wrap [data-option-index]').forEach(group => {
        const btns = group.querySelectorAll('.pdp__swatch, .pdp__size-btn');
        btns.forEach(btn => btn.addEventListener('click', () => {
          if (btn.getAttribute('aria-disabled') === 'true') return;
          btns.forEach(b => b.classList.remove('pdp__swatch--active', 'pdp__size-btn--active'));
          btn.classList.add(btn.classList.contains('pdp__swatch') ? 'pdp__swatch--active' : 'pdp__size-btn--active');
          const valEl = document.getElementById(`pdp-opt-val-${+group.dataset.optionIndex + 1}`);
          if (valEl) valEl.textContent = btn.dataset.value;

          if (btn.classList.contains('pdp__swatch') && btn.dataset.mediaId) {
            navigateGalleryToMedia(btn.dataset.mediaId);
          }

          refreshVariantSection();
        }));
      });
    }

    bindOptionClicks();

    /* ── Campos Personalizados — radio ── */
    document.querySelectorAll('.pdp__custom-field__radio-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const group = btn.closest('.pdp__custom-field');
        group?.querySelectorAll('.pdp__custom-field__radio-btn').forEach(b => b.classList.remove('is-selected'));
        btn.classList.add('is-selected');
        const hidden = group?.querySelector('.pdp__custom-field__radio-val');
        if (hidden) hidden.value = btn.dataset.value;
        group?.classList.remove('pdp__custom-field--error');
      });
    });

    document.getElementById('pdp-form')?.addEventListener('input', e => {
      if (e.target.dataset.cfRequired) {
        e.target.closest('.pdp__custom-field')?.classList.remove('pdp__custom-field--error');
      }
    });

    /* ── Wishlist ── */
    const wishBtn = document.getElementById('pdp-wishlist');
    wishBtn?.addEventListener('click', () => {
      const on = wishBtn.classList.toggle('is-active');
      wishBtn.setAttribute('aria-pressed', on);
      wishBtn.querySelector('.material-symbols-outlined').style.fontVariationSettings = on ? "'FILL' 1" : "'FILL' 0";
    });

    /* ── Add to cart AJAX ── */
    document.getElementById('pdp-form')?.addEventListener('submit', async e => {
      e.preventDefault();

      /* Validate required custom fields */
      let cfValid = true;
      e.target.querySelectorAll('[data-cf-required]').forEach(field => {
        const wrap = field.closest('.pdp__custom-field');
        if (!field.value.trim()) { cfValid = false; wrap?.classList.add('pdp__custom-field--error'); }
        else wrap?.classList.remove('pdp__custom-field--error');
      });
      if (!cfValid) return;

      /* Validate pingente (se cliente optou por adicionar) */
      if (window.amePingente?.isActive()) {
        const pv = window.amePingente.validate();
        if (!pv.ok) {
          alert(pv.msg);
          return;
        }
      }

      const btn  = document.getElementById('pdp-add-btn');
      const orig = btn.innerHTML;

      btn.innerHTML = '<span class="material-symbols-outlined" style="font-size:1rem;animation:pdp-spin 0.6s linear infinite;">refresh</span>';
      btn.disabled  = true;
      btn.setAttribute('aria-busy', 'true');

      try {
        /* Monta item da coleira a partir do form */
        const form = e.target;
        const coleiraId = form.querySelector('#pdp-variant-id')?.value;
        const coleiraQty = parseInt(form.querySelector('#pdp-qty')?.value || '1', 10);
        const coleiraProps = {};
        form.querySelectorAll('[name^="properties["]').forEach(el => {
          if (!el.value || !el.value.trim()) return;
          const key = el.name.replace(/^properties\[/, '').replace(/\]$/, '');
          coleiraProps[key] = el.value.trim();
        });
        const items = [{
          id: coleiraId,
          quantity: coleiraQty,
          ...(Object.keys(coleiraProps).length ? { properties: coleiraProps } : {})
        }];

        /* Adiciona pingente como item separado, se aplicável */
        if (window.amePingente?.isActive()) {
          const pingenteItem = window.amePingente.getCartItem();
          if (pingenteItem) items.push(pingenteItem);
        }

        const res = await fetch('/cart/add.js', {
          method:  'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json'
          },
          body: JSON.stringify({ items })
        });

        if (!res.ok) throw new Error('cart/add failed');

        /* Busca carrinho atualizado e repassa ao drawer */
        const cartData = await (await fetch('/cart.js')).json();
        window.AmeCart?.refresh(cartData);
        window.AmeCart?.open();

        /* Feedback no botão */
        btn.innerHTML = 'Adicionado ✓';
        btn.removeAttribute('aria-busy');
        setTimeout(() => { btn.innerHTML = orig; btn.disabled = false; }, 1800);

      } catch {
        btn.innerHTML = 'Tente novamente';
        btn.style.opacity = '0.7';
        btn.removeAttribute('aria-busy');
        setTimeout(() => { btn.innerHTML = orig; btn.disabled = false; btn.style.opacity = ''; }, 2000);
      }
    });

    /* ── Acordeões ── */
    document.querySelectorAll('.ame-accordion__btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const open = btn.getAttribute('aria-expanded') === 'true';
        document.querySelectorAll('.ame-accordion__btn').forEach(b => {
          b.setAttribute('aria-expanded', 'false');
          b.nextElementSibling.setAttribute('hidden', '');
          b.nextElementSibling.style.maxHeight = '0';
        });
        if (!open) {
          btn.setAttribute('aria-expanded', 'true');
          btn.nextElementSibling.removeAttribute('hidden');
          btn.nextElementSibling.style.maxHeight = '600px';
        }
      });
    });
  })();
</script>

{% stylesheet %}
  .pdp__custom-field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .pdp__custom-field__label {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-on-surface-variant, #4f4442);
    font-weight: 600;
  }

  .pdp__custom-field__req {
    color: var(--color-primary, #5a4742);
  }

  .pdp__custom-field__input,
  .pdp__custom-field__textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-outline-variant, #d2c3c0);
    border-radius: var(--radius-md, 4px);
    background: transparent;
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.875rem;
    color: var(--color-on-background, #201b14);
    transition: border-color 0.2s ease;
    outline: none;
  }

  .pdp__custom-field__input:focus,
  .pdp__custom-field__textarea:focus {
    border-color: var(--color-primary, #5a4742);
  }

  .pdp__custom-field__textarea {
    resize: vertical;
    min-height: 5rem;
  }

  .pdp__custom-field__helper {
    font-size: 0.75rem;
    color: var(--color-on-surface-variant, #4f4442);
    opacity: 0.7;
    margin: 0;
  }

  .pdp__custom-field__radio-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .pdp__custom-field__radio-btn {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-outline-variant, #d2c3c0);
    border-radius: var(--radius-md, 4px);
    background: transparent;
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.875rem;
    color: var(--color-on-background, #201b14);
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .pdp__custom-field__radio-btn:hover,
  .pdp__custom-field__radio-btn.is-selected {
    border-color: var(--color-primary, #5a4742);
    background: var(--color-surface-container, #f8ece0);
  }

  .pdp__custom-field__radio-btn.is-selected {
    font-weight: 600;
  }

  .pdp__custom-field__error-msg {
    font-size: 0.75rem;
    color: #c0392b;
    margin: 0;
    display: none;
  }

  .pdp__custom-field--error .pdp__custom-field__error-msg {
    display: block;
  }

  .pdp__custom-field--error .pdp__custom-field__label {
    color: #c0392b;
  }

  .pdp__custom-field--error .pdp__custom-field__input,
  .pdp__custom-field--error .pdp__custom-field__textarea {
    border-color: #c0392b;
  }

  .pdp__custom-field--error .pdp__custom-field__radio-btn {
    border-color: #c0392b;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Produto",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_related",
      "label": "Exibir produtos relacionados",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Acordeão de detalhes",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Materiais & Craft"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Conteúdo",
          "default": "<p>Descreva os materiais, tamanhos ou instruções de cuidado.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Produto",
      "blocks": [
        { "type": "accordion", "settings": { "title": "Materiais & Craft" } },
        { "type": "accordion", "settings": { "title": "Guia de Tamanhos" } },
        { "type": "accordion", "settings": { "title": "Cuidados & Manutenção" } },
        { "type": "accordion", "settings": { "title": "Envio & Embalagem" } }
      ]
    }
  ],
  "disabled_on": { "groups": ["header", "footer"] }
}
{% endschema %}
