{% comment %} Âme — Página de Produto: carousel + form + acordeões + relacionados {% endcomment %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign media_size = product.media.size
-%}

<!-- Breadcrumb -->
<nav class="ame-pdp-breadcrumb full-width" aria-label="Navegação">
  <a href="{{ routes.root_url }}">Início</a>
  <span aria-hidden="true">/</span>
  {%- if collection -%}
    <a href="{{ collection.url }}">{{ collection.title }}</a>
    <span aria-hidden="true">/</span>
  {%- endif -%}
  <span aria-current="page">{{ product.title }}</span>
</nav>

<!-- Main product layout -->
<div class="ame-pdp full-width">

  <!-- LEFT: Carousel -->
  <div class="ame-pdp__gallery">
    <div class="ame-pdp__carousel" id="ame-carousel" aria-label="Galeria do produto">
      <!-- Prev / Next hit areas -->
      <button class="ame-pdp__carousel-btn ame-pdp__carousel-btn--prev" id="ame-carousel-prev" aria-label="Anterior">
        <span class="material-symbols-outlined" style="font-variation-settings:'wght' 300;">arrow_back</span>
      </button>
      <button class="ame-pdp__carousel-btn ame-pdp__carousel-btn--next" id="ame-carousel-next" aria-label="Próximo">
        <span class="material-symbols-outlined" style="font-variation-settings:'wght' 300;">arrow_forward</span>
      </button>

      <div class="ame-pdp__track" id="ame-carousel-track">
        {%- if media_size > 0 -%}
          {%- for media in product.media -%}
            <div class="ame-pdp__slide">
              {%- if media.media_type == 'image' -%}
                {{
                  media
                  | image_url: width: 1200
                  | image_tag: loading: 'lazy', class: 'ame-pdp__slide-img', alt: media.alt | default: product.title | escape
                }}
              {%- elsif media.media_type == 'video' -%}
                {{ media | video_tag: class: 'ame-pdp__slide-img', autoplay: false, loop: true, muted: true }}
              {%- endif -%}
            </div>
          {%- endfor -%}
        {%- else -%}
          <div class="ame-pdp__slide">
            {{ 'product-1' | placeholder_svg_tag: 'ame-pdp__slide-img ame-pdp__slide-img--placeholder' }}
          </div>
        {%- endif -%}
      </div>

      <div class="ame-pdp__carousel-counter" aria-live="polite">
        <span id="ame-slide-current">1</span> / {{ media_size | at_least: 1 }}
      </div>
    </div>

    <!-- Thumbnails -->
    {%- if media_size > 1 -%}
      <div class="ame-pdp__thumbs no-scrollbar" role="list">
        {%- for media in product.media -%}
          <button
            class="ame-pdp__thumb{% if forloop.first %} ame-pdp__thumb--active{% endif %}"
            data-index="{{ forloop.index0 }}"
            aria-label="Imagem {{ forloop.index }}"
            role="listitem"
          >
            {{
              media.preview_image
              | image_url: width: 200
              | image_tag: loading: 'lazy', alt: '', class: 'ame-pdp__thumb-img'
            }}
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <!-- RIGHT: Product info -->
  <div class="ame-pdp__info">

    <!-- Badge + eyebrow -->
    <div class="ame-pdp__meta ame-fade-up ame-delay-1">
      {%- for tag in product.tags -%}
        {%- if tag == 'heritage' or tag == 'Heritage' -%}
          <span class="ame-chip">Heritage Series</span>
        {%- endif -%}
      {%- endfor -%}
      {%- if product.available == false -%}
        <span class="ame-chip">Esgotado</span>
      {%- endif -%}
    </div>

    <!-- Title -->
    <h1 class="ame-pdp__title ame-fade-up ame-delay-2">{{ product.title }}</h1>

    <!-- Rating placeholder (substituir por app de avaliações) -->
    <div class="ame-pdp__rating ame-fade-up ame-delay-2" aria-label="4.8 de 5 estrelas">
      <div class="ame-pdp__stars" aria-hidden="true">
        <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1; font-size:1rem; color:var(--color-primary);">star</span>
        <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1; font-size:1rem; color:var(--color-primary);">star</span>
        <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1; font-size:1rem; color:var(--color-primary);">star</span>
        <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1; font-size:1rem; color:var(--color-primary);">star</span>
        <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 0; font-size:1rem; color:var(--color-outline-variant);">star</span>
      </div>
      <span class="ame-pdp__rating-count">4.8 · 32 avaliações</span>
    </div>

    <!-- Price -->
    <p class="ame-pdp__price ame-fade-up ame-delay-3" id="ame-price">
      {%- if current_variant.compare_at_price > current_variant.price -%}
        <s class="ame-pdp__price-compare">{{ current_variant.compare_at_price | money }}</s>
      {%- endif -%}
      {{ current_variant.price | money }}
    </p>

    <!-- Cashback -->
    <div class="ame-fade-up ame-delay-3" id="ame-cashback-wrap">
      {%- render 'cashback', cashback_price: current_variant.price, cashback_mode: 'pdp' -%}
    </div>

    <!-- Description -->
    {%- if product.description != blank -%}
      <div class="ame-pdp__desc ame-fade-up ame-delay-3">{{ product.description }}</div>
    {%- endif -%}

    <!-- Product form -->
    <script id="ame-variants-json" type="application/json">
      {{ product.variants | json }}
    </script>

    {%- form 'product', product, id: 'ame-product-form', novalidate: true -%}
      <input type="hidden" name="id" value="{{ current_variant.id }}" id="ame-variant-id">

      <!-- Options (Cor, Tamanho, etc.) -->
      {%- for option in product.options_with_values -%}
        <div class="ame-pdp__option ame-fade-up ame-delay-4">
          <div class="ame-pdp__option-header">
            <span class="ame-pdp__option-name">{{ option.name }}</span>
            <span class="ame-pdp__option-value" id="ame-option-val-{{ forloop.index }}">{{ option.selected_value }}</span>
          </div>

          {%- liquid
            assign is_color = false
            if option.name == 'Color' or option.name == 'Cor' or option.name == 'Acabamento'
              assign is_color = true
            endif
          -%}

          {%- if is_color -%}
            <div class="ame-pdp__swatches" data-option-index="{{ forloop.index0 }}">
              {%- for value in option.values -%}
                {%- liquid
                  assign swatch_img_url = ''
                  for variant in product.variants
                    assign opt_pos = option.position | minus: 1
                    if opt_pos == 0 and variant.option1 == value
                      assign swatch_img_url = variant.featured_image | image_url: width: 120
                      break
                    elsif opt_pos == 1 and variant.option2 == value
                      assign swatch_img_url = variant.featured_image | image_url: width: 120
                      break
                    elsif opt_pos == 2 and variant.option3 == value
                      assign swatch_img_url = variant.featured_image | image_url: width: 120
                      break
                    endif
                  endfor
                -%}
                <button
                  type="button"
                  class="ame-pdp__swatch{% if value == option.selected_value %} ame-pdp__swatch--active{% endif %}"
                  data-value="{{ value }}"
                  aria-label="{{ value }}"
                  title="{{ value }}"
                >
                  {%- if swatch_img_url != '' -%}
                    <img src="{{ swatch_img_url }}" alt="{{ value | escape }}" class="ame-pdp__swatch-img" loading="lazy" width="120" height="120">
                  {%- else -%}
                    <span
                      class="ame-pdp__swatch-color"
                      style="background: var(--swatch-{{ value | downcase | replace: ' ', '-' }}, var(--color-surface-container, #f8ece0));"
                    ></span>
                  {%- endif -%}
                </button>
              {%- endfor -%}
            </div>
          {%- else -%}
            <div class="ame-pdp__size-grid" data-option-index="{{ forloop.index0 }}">
              {%- for value in option.values -%}
                <button
                  type="button"
                  class="ame-pdp__size-btn{% if value == option.selected_value %} ame-pdp__size-btn--active{% endif %}"
                  data-value="{{ value }}"
                >{{ value }}</button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}

      <!-- Quantity -->
      <div class="ame-pdp__qty ame-fade-up ame-delay-4">
        <span class="ame-pdp__option-name">Quantidade</span>
        <div class="ame-pdp__qty-ctrl">
          <button type="button" class="ame-pdp__qty-btn" id="ame-qty-minus" aria-label="Diminuir">−</button>
          <input type="number" name="quantity" id="ame-qty" value="1" min="1" class="ame-pdp__qty-input" aria-label="Quantidade">
          <button type="button" class="ame-pdp__qty-btn" id="ame-qty-plus" aria-label="Aumentar">+</button>
        </div>
      </div>

      <!-- CTAs -->
      <div class="ame-pdp__ctas ame-fade-up ame-delay-5">
        <button
          type="submit"
          class="ame-cta ame-pdp__add-btn"
          id="ame-add-btn"
          {% unless current_variant.available %}disabled{% endunless %}
        >
          {%- if current_variant.available -%}
            Adicionar ao Carrinho
            <span class="material-symbols-outlined" style="font-size:1rem;">shopping_bag</span>
          {%- else -%}
            Esgotado
          {%- endif -%}
        </button>

        <button type="button" class="ame-pdp__wishlist-btn ame-wishlist" aria-label="Favoritar" id="ame-wishlist">
          <span class="material-symbols-outlined" style="font-size:1.25rem; font-variation-settings:'FILL' 0;">favorite</span>
        </button>
      </div>

      {{ form | payment_button }}
    {%- endform -%}

    <!-- Value props -->
    <div class="ame-pdp__props ame-fade-up ame-delay-5">
      <div class="ame-pdp__prop">
        <span class="material-symbols-outlined" style="font-variation-settings:'wght' 250;">local_shipping</span>
        <span>Frete grátis com embalagem bespoke</span>
      </div>
      <div class="ame-pdp__prop">
        <span class="material-symbols-outlined" style="font-variation-settings:'wght' 250;">autorenew</span>
        <span>Devoluções grátis em 14 dias</span>
      </div>
      <div class="ame-pdp__prop">
        <span class="material-symbols-outlined" style="font-variation-settings:'wght' 250;">workspace_premium</span>
        <span>Garantia vitalícia de artesanato</span>
      </div>
    </div>

  </div>
</div>

<!-- Accordions -->
<div class="ame-pdp-accordions full-width">
  {%- for block in section.blocks -%}
    {%- if block.type == 'accordion' -%}
      <div class="ame-accordion" {{ block.shopify_attributes }}>
        <button class="ame-accordion__btn" type="button" aria-expanded="false">
          <span>{{ block.settings.title }}</span>
          <span class="material-symbols-outlined ame-accordion__icon" style="font-variation-settings:'wght' 300;" aria-hidden="true">add</span>
        </button>
        <div class="ame-accordion__content" hidden>
          <div class="ame-accordion__body">{{ block.settings.body }}</div>
        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}

  <!-- Default: descrição completa se não houver blocos accordion -->
  {%- if section.blocks.size == 0 and product.description != blank -%}
    <div class="ame-accordion">
      <button class="ame-accordion__btn" type="button" aria-expanded="false">
        <span>Detalhes do Produto</span>
        <span class="material-symbols-outlined ame-accordion__icon" style="font-variation-settings:'wght' 300;" aria-hidden="true">add</span>
      </button>
      <div class="ame-accordion__content" hidden>
        <div class="ame-accordion__body">{{ product.description }}</div>
      </div>
    </div>
  {%- endif -%}
</div>

<!-- Related products -->
{%- if section.settings.show_related and recommendations.performed and recommendations.products_count > 0 -%}
  <div class="ame-pdp-related full-width">
    <div class="ame-pdp-related__header ame-reveal">
      <p class="ame-label-sm">Complete o Look</p>
      <h2 class="ame-pdp-related__title">Você Também Vai Amar.</h2>
    </div>
    <div class="ame-pdp-related__grid">
      {%- for rec in recommendations.products limit: 4 -%}
        {%- render 'product-card', card_product: rec -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  /* Breadcrumb */
  .ame-pdp-breadcrumb {
    padding: 1.25rem var(--page-margin, 2rem);
    max-width: var(--page-width, 120rem);
    margin: 0 auto;
    display: flex; align-items: center; gap: 0.5rem;
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.6875rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: rgba(90,71,66,0.4);
  }
  .ame-pdp-breadcrumb a { color: inherit; text-decoration: none; transition: color 0.2s ease; }
  .ame-pdp-breadcrumb a:hover { color: var(--color-primary, #5a4742); }

  /* Main layout */
  .ame-pdp {
    display: flex; flex-direction: column; gap: 3rem;
    padding: 0.5rem var(--page-margin, 2rem) 4rem;
    max-width: var(--page-width, 120rem);
    margin: 0 auto;
  }
  @media (min-width: 1024px) {
    .ame-pdp { flex-direction: row; gap: 4rem; }
    .ame-pdp__gallery { width: 44%; flex-shrink: 0; }
    .ame-pdp__info { flex: 1; padding-top: 2rem; }
  }

  /* Carousel */
  .ame-pdp__carousel {
    position: relative;
    width: 100%; aspect-ratio: 1/1;
    max-height: 80vw;
    background: var(--color-tertiary-fixed, #e7e2de);
    border-radius: var(--radius-lg, 0.5rem);
    overflow: hidden;
    margin-bottom: 1rem;
  }
  @media (min-width: 768px) {
    .ame-pdp__carousel { aspect-ratio: 3/4; max-height: none; }
  }
  .ame-pdp__track {
    display: flex; height: 100%;
    transition: transform 800ms var(--ease-luxury, cubic-bezier(0.22,1,0.36,1));
    will-change: transform;
  }
  .ame-pdp__slide { flex-shrink: 0; width: 100%; height: 100%; }
  .ame-pdp__slide-img {
    width: 100%; height: 100%; object-fit: cover;
    mix-blend-mode: multiply; opacity: 0.9;
  }
  .ame-pdp__slide-img--placeholder { opacity: 0.3; }

  .ame-pdp__carousel-btn {
    position: absolute; top: 0; bottom: 0; z-index: 10;
    width: 20%; background: none; border: none; cursor: pointer;
    display: flex; align-items: center;
    color: rgba(32,27,20,0.6);
  }
  .ame-pdp__carousel-btn--prev { left: 0; justify-content: flex-start; padding-left: 1rem; }
  .ame-pdp__carousel-btn--next { right: 0; justify-content: flex-end; padding-right: 1rem; }
  .ame-pdp__carousel-btn .material-symbols-outlined {
    background: rgba(255,255,255,0.4); backdrop-filter: blur(8px);
    border-radius: 50%; width: 2.5rem; height: 2.5rem;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity 0.25s ease;
  }
  .ame-pdp__carousel:hover .ame-pdp__carousel-btn .material-symbols-outlined { opacity: 1; }

  .ame-pdp__carousel-counter {
    position: absolute; bottom: 1.25rem; right: 1.25rem;
    background: rgba(255,255,255,0.4); backdrop-filter: blur(8px);
    border-radius: var(--radius-full, 0.75rem);
    padding: 0.25rem 0.75rem;
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.625rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(32,27,20,0.6);
  }

  /* Thumbs */
  .ame-pdp__thumbs {
    display: flex; gap: 0.75rem; overflow-x: auto; padding-bottom: 0.25rem;
  }
  .ame-pdp__thumb {
    flex-shrink: 0; width: 5rem; height: 6rem;
    border-radius: var(--radius-md, 0.25rem); overflow: hidden;
    background: var(--color-surface-container, #f8ece0);
    border: none; cursor: pointer; padding: 0;
    opacity: 0.5; transition: opacity 0.25s ease, outline 0.2s ease;
  }
  .ame-pdp__thumb--active { opacity: 1; outline: 1.5px solid var(--color-primary, #5a4742); outline-offset: 2px; }
  .ame-pdp__thumb:hover { opacity: 0.85; }
  .ame-pdp__thumb-img { width: 100%; height: 100%; object-fit: cover; mix-blend-mode: multiply; }

  /* Info */
  .ame-pdp__meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.25rem; }

  .ame-pdp__title {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: clamp(1.875rem, 3.5vw, 3rem);
    font-weight: 500; letter-spacing: -0.025em; line-height: 1.05;
    color: var(--color-on-background, #201b14);
    margin-bottom: 0.75rem;
  }

  .ame-pdp__rating { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem; }
  .ame-pdp__stars { display: flex; gap: 1px; }
  .ame-pdp__rating-count {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.6875rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--color-on-surface-variant, #4f4442);
  }

  .ame-pdp__price {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 1.75rem; color: var(--color-primary, #5a4742);
    margin-bottom: 1.75rem;
    display: flex; align-items: baseline; gap: 0.75rem;
  }
  .ame-pdp__price-compare {
    font-size: 1rem; color: rgba(90,71,66,0.5);
  }

  .ame-pdp__desc {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 1rem; line-height: 1.85;
    color: var(--color-on-surface-variant, #4f4442);
    margin-bottom: 2.5rem;
  }

  /* Options */
  .ame-pdp__option { margin-bottom: 2rem; }
  .ame-pdp__option-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 0.875rem;
  }
  .ame-pdp__option-name {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--color-on-surface, #201b14);
  }
  .ame-pdp__option-value {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.75rem; color: var(--color-outline-variant, #d2c3c0);
  }

  .ame-pdp__swatches { display: flex; gap: 0.625rem; flex-wrap: wrap; }
  .ame-pdp__swatch {
    width: 3.5rem; height: 3.5rem;
    border-radius: var(--radius-md, 0.25rem);
    border: none; cursor: pointer; padding: 0;
    background: var(--color-surface-container, #f8ece0);
    overflow: hidden; position: relative;
    transition: transform 0.25s ease, outline 0.2s ease;
    flex-shrink: 0;
  }
  .ame-pdp__swatch:hover { transform: scale(1.06); }
  .ame-pdp__swatch--active { outline: 2px solid var(--color-primary, #5a4742); outline-offset: 2px; }
  .ame-pdp__swatch-img {
    width: 100%; height: 100%; object-fit: cover;
    mix-blend-mode: multiply; display: block;
  }
  .ame-pdp__swatch-color {
    display: block; width: 100%; height: 100%;
  }

  .ame-pdp__size-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.75rem; }
  .ame-pdp__size-btn {
    padding: 0.75rem; text-align: center;
    border: 1px solid rgba(210,195,192,0.2); border-radius: var(--radius-lg, 0.5rem);
    background: var(--color-surface, #fff8f3);
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.6875rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--color-on-surface, #201b14); cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }
  .ame-pdp__size-btn:hover { background: var(--color-surface-container, #f8ece0); }
  .ame-pdp__size-btn--active {
    border-color: var(--color-primary, #5a4742);
    background: rgba(249,220,214,0.2);
    color: var(--color-primary, #5a4742);
    font-weight: 500;
  }

  /* Qty */
  .ame-pdp__qty { margin-bottom: 2.5rem; }
  .ame-pdp__qty .ame-pdp__option-name { display: block; margin-bottom: 0.875rem; }
  .ame-pdp__qty-ctrl { display: flex; align-items: center; gap: 0; width: fit-content; }
  .ame-pdp__qty-btn {
    width: 2.75rem; height: 2.75rem; border: 1px solid rgba(210,195,192,0.2);
    background: var(--color-surface, #fff8f3); cursor: pointer;
    font-size: 1.125rem; color: var(--color-on-background, #201b14);
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s ease;
  }
  .ame-pdp__qty-btn:first-child { border-radius: var(--radius-md, 0.25rem) 0 0 var(--radius-md, 0.25rem); }
  .ame-pdp__qty-btn:last-child  { border-radius: 0 var(--radius-md, 0.25rem) var(--radius-md, 0.25rem) 0; }
  .ame-pdp__qty-btn:hover { background: var(--color-surface-container, #f8ece0); }
  .ame-pdp__qty-input {
    width: 3.5rem; height: 2.75rem; text-align: center;
    border: 1px solid rgba(210,195,192,0.2); border-left: none; border-right: none;
    border-radius: 0; background: var(--color-surface, #fff8f3);
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.875rem; color: var(--color-on-background, #201b14);
    outline: none;
  }

  /* CTAs */
  .ame-pdp__ctas { display: flex; gap: 0.75rem; margin-bottom: 2rem; }
  .ame-pdp__add-btn { flex: 1; }
  .ame-pdp__add-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none !important; }
  .ame-pdp__wishlist-btn {
    width: 3.5rem; height: 3.5rem; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid rgba(210,195,192,0.2); border-radius: var(--radius-lg, 0.5rem);
    background: transparent; cursor: pointer;
    color: rgba(90,71,66,0.4); transition: color 0.25s ease, border-color 0.25s ease;
  }
  .ame-pdp__wishlist-btn:hover,
  .ame-pdp__wishlist-btn.is-active {
    color: var(--color-primary, #5a4742);
    border-color: rgba(90,71,66,0.3);
  }
  .ame-pdp__wishlist-btn.is-active .material-symbols-outlined { font-variation-settings: 'FILL' 1; }

  /* Value props */
  .ame-pdp__props {
    display: flex; flex-direction: column; gap: 0.875rem;
    padding-top: 1.75rem;
    border-top: 1px solid rgba(210,195,192,0.15);
  }
  .ame-pdp__prop {
    display: flex; align-items: center; gap: 1rem;
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.875rem; color: var(--color-on-surface-variant, #4f4442);
  }
  .ame-pdp__prop .material-symbols-outlined {
    font-size: 1.25rem; color: var(--color-outline, #817471); flex-shrink: 0;
  }

  /* Accordions */
  .ame-pdp-accordions {
    padding: 0 var(--page-margin, 2rem) 4rem;
    max-width: min(48rem, var(--page-width, 120rem));
    margin: 0 auto;
  }
  .ame-accordion { border-top: 1px solid rgba(210,195,192,0.2); }
  .ame-accordion:last-child { border-bottom: 1px solid rgba(210,195,192,0.2); }
  .ame-accordion__btn {
    width: 100%; display: flex; align-items: center; justify-content: space-between;
    padding: 1.5rem 0; background: none; border: none; cursor: pointer; text-align: left;
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--color-on-background, #201b14);
  }
  .ame-accordion__btn:hover { color: var(--color-primary, #5a4742); }
  .ame-accordion__icon { transition: transform 0.3s ease; }
  .ame-accordion__btn[aria-expanded="true"] .ame-accordion__icon { transform: rotate(45deg); }
  .ame-accordion__content {
    overflow: hidden;
    transition: max-height 0.4s var(--ease-luxury, cubic-bezier(0.22,1,0.36,1));
    max-height: 0;
  }
  .ame-accordion__content:not([hidden]) { max-height: 600px; }
  .ame-accordion__body {
    padding-bottom: 2rem; padding-right: 2rem;
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.9375rem; line-height: 1.85;
    color: var(--color-on-surface-variant, #4f4442);
  }
  .ame-accordion__body ul { padding-left: 1.25rem; display: flex; flex-direction: column; gap: 0.5rem; }

  /* Related */
  .ame-pdp-related {
    padding: 4rem var(--page-margin, 2rem) var(--section-gap, 7.5rem);
    max-width: var(--page-width, 120rem);
    margin: 0 auto;
  }
  .ame-pdp-related__header { margin-bottom: 3.5rem; }
  .ame-pdp-related__title {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700; letter-spacing: -0.025em;
    color: var(--color-on-background, #201b14);
  }
  .ame-pdp-related__grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem 1.5rem;
  }
  @media (min-width: 768px) { .ame-pdp-related__grid { grid-template-columns: repeat(4, 1fr); } }

  .ame-label-sm {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.625rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: rgba(90,71,66,0.5); display: block; margin-bottom: 0.5rem;
  }
{% endstylesheet %}

<script>
  (() => {
    /* ── Carousel ── */
    const track  = document.getElementById('ame-carousel-track');
    const thumbs = document.querySelectorAll('.ame-pdp__thumb');
    const counter = document.getElementById('ame-slide-current');
    let current = 0;
    const total  = thumbs.length || 1;

    function goTo(index) {
      current = Math.max(0, Math.min(index, total - 1));
      track.style.transform = `translateX(-${current * 100}%)`;
      thumbs.forEach((t, i) => t.classList.toggle('ame-pdp__thumb--active', i === current));
      if (counter) counter.textContent = current + 1;
    }

    document.getElementById('ame-carousel-prev')?.addEventListener('click', () => goTo(current - 1));
    document.getElementById('ame-carousel-next')?.addEventListener('click', () => goTo(current + 1));
    thumbs.forEach(t => t.addEventListener('click', () => goTo(parseInt(t.dataset.index))));

    /* Swipe */
    let tx = 0;
    track?.addEventListener('touchstart', e => { tx = e.touches[0].clientX; }, { passive: true });
    track?.addEventListener('touchend',   e => {
      const dx = tx - e.changedTouches[0].clientX;
      if (Math.abs(dx) > 40) goTo(dx > 0 ? current + 1 : current - 1);
    });

    /* ── Qty ── */
    const qtyInput = document.getElementById('ame-qty');
    document.getElementById('ame-qty-minus')?.addEventListener('click', () => {
      if (qtyInput && qtyInput.value > 1) qtyInput.value = parseInt(qtyInput.value) - 1;
    });
    document.getElementById('ame-qty-plus')?.addEventListener('click', () => {
      if (qtyInput) qtyInput.value = parseInt(qtyInput.value) + 1;
    });

    /* ── Option selectors ── */
    document.querySelectorAll('[data-option-index]').forEach(group => {
      const btns = group.querySelectorAll('.ame-pdp__swatch, .ame-pdp__size-btn');
      btns.forEach(btn => {
        btn.addEventListener('click', () => {
          btns.forEach(b => b.classList.remove('ame-pdp__swatch--active', 'ame-pdp__size-btn--active'));
          btn.classList.add(btn.classList.contains('ame-pdp__swatch') ? 'ame-pdp__swatch--active' : 'ame-pdp__size-btn--active');
          const idx = group.dataset.optionIndex;
          const valEl = document.getElementById(`ame-option-val-${parseInt(idx)+1}`);
          if (valEl) valEl.textContent = btn.dataset.value;
          updateVariant();
        });
      });
    });

    function updateVariant() {
      const opts = [];
      document.querySelectorAll('[data-option-index]').forEach(g => {
        const active = g.querySelector('.ame-pdp__swatch--active, .ame-pdp__size-btn--active');
        if (active) opts.push(active.dataset.value);
      });
      const variantData = JSON.parse(document.getElementById('ame-variants-json')?.textContent || '[]');
      const matched = variantData.find(v => opts.every((o, i) => v.options[i] === o));
      if (matched) {
        document.getElementById('ame-variant-id').value = matched.id;
        const priceEl = document.getElementById('ame-price');
        if (priceEl) {
          const fmt = typeof Shopify !== 'undefined' && Shopify.formatMoney
            ? Shopify.formatMoney(matched.price, '{{ shop.money_format }}')
            : 'R$ ' + (matched.price / 100).toFixed(2).replace('.', ',');
          priceEl.innerHTML = matched.available ? fmt : 'Esgotado';
        }
        const addBtn = document.getElementById('ame-add-btn');
        if (addBtn) addBtn.disabled = !matched.available;
        updateCashback(matched.price);
      }
    }

    function updateCashback(priceCents) {
      const wrap = document.getElementById('ame-cashback-wrap');
      if (!wrap) return;
      const el = wrap.querySelector('[data-cashback]');
      if (!el) return;
      const pct = parseFloat(el.dataset.pct) || 8;
      const min = parseFloat(el.dataset.min) || 10;
      const cb  = (priceCents / 100) * (pct / 100);
      const cifra = el.querySelector('.ame-cashback__cifra');
      const val   = el.querySelector('[data-cashback-value]');
      if (!val) return;
      if (cb >= min) {
        if (cifra) cifra.style.display = '';
        val.textContent = cb.toFixed(2).replace('.', ',');
      } else {
        if (cifra) cifra.style.display = 'none';
        val.textContent = Math.round(pct) + '%';
      }
    }

    /* ── Wishlist ── */
    const wishlistBtn = document.getElementById('ame-wishlist');
    wishlistBtn?.addEventListener('click', () => {
      const active = wishlistBtn.classList.toggle('is-active');
      wishlistBtn.querySelector('.material-symbols-outlined').style.fontVariationSettings = active ? "'FILL' 1" : "'FILL' 0";
    });

    /* ── Add to cart AJAX ── */
    document.getElementById('ame-product-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('ame-add-btn');
      const orig = btn.innerHTML;
      btn.innerHTML = 'Adicionado ✓';
      btn.disabled = true;
      await fetch('/cart/add.js', { method: 'POST', body: new FormData(e.target) });
      setTimeout(() => { btn.innerHTML = orig; btn.disabled = false; }, 1800);
    });

    /* ── Accordions ── */
    document.querySelectorAll('.ame-accordion__btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        /* Close all */
        document.querySelectorAll('.ame-accordion__btn').forEach(b => {
          b.setAttribute('aria-expanded', 'false');
          b.nextElementSibling.setAttribute('hidden', '');
          b.nextElementSibling.style.maxHeight = '0';
        });
        if (!expanded) {
          btn.setAttribute('aria-expanded', 'true');
          const content = btn.nextElementSibling;
          content.removeAttribute('hidden');
          content.style.maxHeight = '600px';
        }
      });
    });
  })();
</script>

