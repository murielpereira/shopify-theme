{% comment %} Âme — Página de Produto {% endcomment %}

{%- liquid
  assign cv = product.selected_or_first_available_variant
  assign media_size = product.media.size
-%}

<!-- Breadcrumb -->
<nav class="pdp-breadcrumb full-width" aria-label="Navegação">
  <a href="{{ routes.root_url }}">Início</a>
  <span aria-hidden="true">/</span>
  {%- if collection -%}
    <a href="{{ collection.url }}">{{ collection.title }}</a>
    <span aria-hidden="true">/</span>
  {%- endif -%}
  <span aria-current="page">{{ product.title }}</span>
</nav>

<!-- ═══════════════════════════════════════
     PÁGINA DE PRODUTO — layout principal
     Mobile: coluna única (título → galeria → info)
     Desktop: duas colunas (galeria | info)
════════════════════════════════════════ -->
<div class="pdp full-width">

  <!-- ── Coluna esquerda: galeria ── -->
  <div class="pdp__gallery">

    <!-- Imagem principal -->
    <div class="pdp__main-img-wrap">
      {%- if media_size > 0 -%}
          <div class="pdp__track" id="pdp-track">
          {%- for media in product.media -%}
            <div class="pdp__slide">
              {%- if media.media_type == 'image' -%}
                {{- media | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'pdp__slide-img', alt: media.alt | default: product.title | escape -}}
              {%- elsif media.media_type == 'video' -%}
                {{ media | video_tag: class: 'pdp__slide-img', autoplay: false, loop: true, muted: true }}
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
        <!-- contador -->
        <div class="pdp__counter" aria-live="polite">
          <span id="pdp-current">1</span> / {{ media_size }}
        </div>
        <!-- botões de navegação -->
        <button class="pdp__nav pdp__nav--prev" id="pdp-prev" aria-label="Anterior">
          <span class="material-symbols-outlined">arrow_back_ios</span>
        </button>
        <button class="pdp__nav pdp__nav--next" id="pdp-next" aria-label="Próximo">
          <span class="material-symbols-outlined">arrow_forward_ios</span>
        </button>
      {%- else -%}
        <div class="pdp__track" id="pdp-track">
          <div class="pdp__slide">
            {{ 'product-1' | placeholder_svg_tag: 'pdp__slide-img pdp__slide-img--placeholder' }}
          </div>
        </div>
      {%- endif -%}
    </div>

    <!-- Thumbnails em linha horizontal com scroll -->
    {%- if media_size > 1 -%}
      <div class="pdp__thumbs no-scrollbar" role="list">
        {%- for media in product.media -%}
          <button
            class="pdp__thumb{% if forloop.first %} pdp__thumb--active{% endif %}"
            data-index="{{ forloop.index0 }}"
            aria-label="Imagem {{ forloop.index }}"
            role="listitem"
            type="button"
          >
            {{- media.preview_image | image_url: width: 160 | image_tag: loading: 'lazy', alt: '', class: 'pdp__thumb-img' -}}
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>

  <!-- ── Coluna direita: informações ── -->
  <div class="pdp__info">

    <!-- Badge de coleção / heritage -->
    {%- liquid
      assign show_meta = false
      for tag in product.tags
        if tag == 'heritage' or tag == 'Heritage'
          assign show_meta = true
        endif
      endfor
      if product.available == false
        assign show_meta = true
      endif
    -%}
    {%- if show_meta -%}
      <div class="pdp__meta">
        {%- for tag in product.tags -%}
          {%- if tag == 'heritage' or tag == 'Heritage' -%}
            <span class="ame-chip">Heritage Series</span>
          {%- endif -%}
        {%- endfor -%}
        {%- if product.available == false -%}
          <span class="ame-chip">Esgotado</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- Título -->
    <h1 class="pdp__title">{{ product.title }}</h1>

    <!-- Rating (placeholder — substituir por app) -->
    <div class="pdp__rating" aria-label="4.8 de 5 estrelas">
      <div class="pdp__stars" aria-hidden="true">
        <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;font-size:0.9rem;color:var(--color-primary);">star</span>
        <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;font-size:0.9rem;color:var(--color-primary);">star</span>
        <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;font-size:0.9rem;color:var(--color-primary);">star</span>
        <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;font-size:0.9rem;color:var(--color-primary);">star</span>
        <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 0;font-size:0.9rem;color:var(--color-outline-variant);">star</span>
      </div>
      <span class="pdp__rating-text">4.8 · 32 avaliações</span>
    </div>

    <!-- ── Bloco de preços ── -->
    {%- liquid
      assign has_compare = false
      if cv.compare_at_price > cv.price
        assign has_compare = true
        assign discount_pct = cv.compare_at_price | minus: cv.price | times: 100 | divided_by: cv.compare_at_price
      endif
      assign pix_pct        = section.settings.pix_discount | default: 5
      assign pix_price_cents = cv.price | times: pix_pct | divided_by: 100
      assign pix_price_cents = cv.price | minus: pix_price_cents
      assign inst_count     = section.settings.installments_count | default: 3
      assign inst_value     = cv.price | divided_by: inst_count
    -%}

    <div class="pdp__price-block">

      <!-- Linha "De:" riscado + badge desconto -->
      {%- if has_compare -%}
        <div class="pdp__price-compare-row">
          <s class="pdp__price-compare">De: {{ cv.compare_at_price | money }}</s>
          <span class="pdp__discount-badge">−{{ discount_pct }}% OFF</span>
        </div>
      {%- endif -%}

      <!-- Preço no cartão -->
      <div class="pdp__price-card-row">
        <span class="pdp__price-label">a partir de</span>
        <strong class="pdp__price-main" id="pdp-price">{{ cv.price | money }}</strong>
        <span class="pdp__price-label">no cartão</span>
      </div>

      <!-- Preço no Pix -->
      {%- if section.settings.show_pix -%}
        <div class="pdp__price-pix-row">
          <span class="pdp__price-label">ou</span>
          <strong class="pdp__price-pix" id="pdp-price-pix">{{ pix_price_cents | money }}</strong>
          <span class="pdp__price-label">com Pix</span>
        </div>
      {%- endif -%}

      <!-- Parcelamento -->
      {%- if section.settings.show_installments and inst_count > 1 -%}
        <p class="pdp__installments">
          Até <strong>{{ inst_count }}x</strong> de <strong id="pdp-inst-value">{{ inst_value | money }}</strong> sem juros
          {%- if section.settings.show_installments_link -%}
            <a href="#" class="pdp__installments-link">Ver mais detalhes</a>
          {%- endif -%}
        </p>
      {%- endif -%}

      <!-- Cashback -->
      <div id="pdp-cashback-wrap">
        {%- render 'cashback', cashback_price: cv.price, cashback_mode: 'pdp' -%}
      </div>

    </div>

    <!-- ── Descrição curta ── -->
    {%- if product.description != blank -%}
      <div class="pdp__desc">{{ product.description }}</div>
    {%- endif -%}

    <!-- ── Formulário de produto ── -->
    <script id="pdp-variants-json" type="application/json">{{ product.variants | json }}</script>

    {%- form 'product', product, id: 'pdp-form', novalidate: true -%}
      <input type="hidden" name="id" value="{{ cv.id }}" id="pdp-variant-id">

      <!-- Opções (Cor, Tamanho...) -->
      {%- for option in product.options_with_values -%}
        {%- liquid
          assign is_color = false
          if option.name == 'Color' or option.name == 'Cor' or option.name == 'Acabamento'
            assign is_color = true
          endif
        -%}

        <div class="pdp__option" data-option-index="{{ forloop.index0 }}">
          <div class="pdp__option-header">
            <span class="pdp__option-label">{{ option.name }}</span>
            <span class="pdp__option-value" id="pdp-opt-val-{{ forloop.index }}">{{ option.selected_value }}</span>
          </div>

          {%- if is_color -%}
            <!-- Grade de swatches por imagem (6 colunas no mobile) -->
            <div class="pdp__swatches" data-option-index="{{ forloop.index0 }}">
              {%- for value in option.values -%}
                {%- liquid
                  assign sw_img = ''
                  assign opt_pos = option.position | minus: 1
                  for variant in product.variants
                    assign matches = false
                    if opt_pos == 0 and variant.option1 == value
                      assign matches = true
                    elsif opt_pos == 1 and variant.option2 == value
                      assign matches = true
                    elsif opt_pos == 2 and variant.option3 == value
                      assign matches = true
                    endif
                    if matches and variant.featured_image != blank
                      assign sw_img = variant.featured_image | image_url: width: 120
                      break
                    endif
                  endfor
                -%}
                <button
                  type="button"
                  class="pdp__swatch{% if value == option.selected_value %} pdp__swatch--active{% endif %}"
                  data-value="{{ value }}"
                  aria-label="{{ value }}"
                  title="{{ value }}"
                >
                  {%- if sw_img != '' -%}
                    <img src="{{ sw_img }}" alt="{{ value | escape }}" class="pdp__swatch-img" loading="lazy" width="120" height="120">
                  {%- else -%}
                    <span class="pdp__swatch-color" style="background:var(--swatch-{{ value | downcase | replace: ' ', '-' }},var(--color-surface-container,#f8ece0));"></span>
                  {%- endif -%}
                </button>
              {%- endfor -%}
            </div>
          {%- else -%}
            <!-- Botões de tamanho -->
            <div class="pdp__sizes" data-option-index="{{ forloop.index0 }}">
              {%- for value in option.values -%}
                <button
                  type="button"
                  class="pdp__size-btn{% if value == option.selected_value %} pdp__size-btn--active{% endif %}"
                  data-value="{{ value }}"
                >{{ value }}</button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}

      <!-- Quantidade -->
      <div class="pdp__qty">
        <span class="pdp__option-label">Quantidade</span>
        <div class="pdp__qty-ctrl">
          <button type="button" class="pdp__qty-btn" id="pdp-qty-minus" aria-label="Diminuir">−</button>
          <input type="number" name="quantity" id="pdp-qty" value="1" min="1" class="pdp__qty-input" aria-label="Quantidade">
          <button type="button" class="pdp__qty-btn" id="pdp-qty-plus" aria-label="Aumentar">+</button>
        </div>
      </div>

      <!-- CTAs -->
      <div class="pdp__ctas">
        <button
          type="submit"
          class="ame-cta pdp__add-btn"
          id="pdp-add-btn"
          {%- unless cv.available %} disabled{%- endunless %}
        >
          {%- if cv.available -%}
            Adicionar ao Carrinho
            <span class="material-symbols-outlined" style="font-size:1rem;">shopping_bag</span>
          {%- else -%}
            Esgotado
          {%- endif -%}
        </button>

        <button type="button" class="pdp__wishlist-btn" aria-label="Favoritar" id="pdp-wishlist">
          <span class="material-symbols-outlined" style="font-size:1.25rem;font-variation-settings:'FILL' 0;">favorite</span>
        </button>
      </div>

      {{ form | payment_button }}
    {%- endform -%}

    <!-- Selos de confiança -->
    <div class="pdp__trust">
      <div class="pdp__trust-item">
        <span class="material-symbols-outlined" style="font-variation-settings:'wght' 250;">local_shipping</span>
        <span>Frete grátis com embalagem bespoke</span>
      </div>
      <div class="pdp__trust-item">
        <span class="material-symbols-outlined" style="font-variation-settings:'wght' 250;">autorenew</span>
        <span>Devoluções grátis em 14 dias</span>
      </div>
      <div class="pdp__trust-item">
        <span class="material-symbols-outlined" style="font-variation-settings:'wght' 250;">workspace_premium</span>
        <span>Garantia vitalícia de artesanato</span>
      </div>
    </div>

  </div><!-- /pdp__info -->
</div><!-- /pdp -->

<!-- ── Acordeões de detalhes ── -->
<div class="pdp-accordions full-width">
  {%- for block in section.blocks -%}
    {%- if block.type == 'accordion' -%}
      <div class="ame-accordion" {{ block.shopify_attributes }}>
        <button class="ame-accordion__btn" type="button" aria-expanded="false">
          <span>{{ block.settings.title }}</span>
          <span class="material-symbols-outlined ame-accordion__icon" style="font-variation-settings:'wght' 300;" aria-hidden="true">add</span>
        </button>
        <div class="ame-accordion__content" hidden>
          <div class="ame-accordion__body">{{ block.settings.body }}</div>
        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}

  {%- if section.blocks.size == 0 and product.description != blank -%}
    <div class="ame-accordion">
      <button class="ame-accordion__btn" type="button" aria-expanded="false">
        <span>Detalhes do Produto</span>
        <span class="material-symbols-outlined ame-accordion__icon" style="font-variation-settings:'wght' 300;" aria-hidden="true">add</span>
      </button>
      <div class="ame-accordion__content" hidden>
        <div class="ame-accordion__body">{{ product.description }}</div>
      </div>
    </div>
  {%- endif -%}
</div>

<!-- ── Produtos relacionados ── -->
{%- if section.settings.show_related and recommendations.performed and recommendations.products_count > 0 -%}
  <div class="ame-pdp-related full-width">
    <div class="ame-pdp-related__header ame-reveal">
      <p class="ame-label-sm">Complete o Look</p>
      <h2 class="ame-pdp-related__title">Você Também Vai Amar.</h2>
    </div>
    <div class="ame-pdp-related__grid">
      {%- for rec in recommendations.products limit: 4 -%}
        {%- render 'product-card', card_product: rec -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

<script>
  (() => {
    /* ── Carousel ── */
    const track   = document.getElementById('pdp-track');
    const thumbs  = document.querySelectorAll('.pdp__thumb');
    const counter = document.getElementById('pdp-current');
    let cur = 0;
    const total = thumbs.length || 1;

    function goTo(i) {
      cur = Math.max(0, Math.min(i, total - 1));
      track.style.transform = `translateX(-${cur * 100}%)`;
      thumbs.forEach((t, idx) => t.classList.toggle('pdp__thumb--active', idx === cur));
      if (counter) counter.textContent = cur + 1;
    }

    document.getElementById('pdp-prev')?.addEventListener('click', () => goTo(cur - 1));
    document.getElementById('pdp-next')?.addEventListener('click', () => goTo(cur + 1));
    thumbs.forEach(t => t.addEventListener('click', () => goTo(+t.dataset.index)));

    /* swipe */
    let sx = 0;
    track?.addEventListener('touchstart', e => { sx = e.touches[0].clientX; }, { passive: true });
    track?.addEventListener('touchend',   e => {
      const dx = sx - e.changedTouches[0].clientX;
      if (Math.abs(dx) > 40) goTo(dx > 0 ? cur + 1 : cur - 1);
    });

    /* ── Quantidade ── */
    const qtyInput = document.getElementById('pdp-qty');
    document.getElementById('pdp-qty-minus')?.addEventListener('click', () => {
      if (qtyInput && +qtyInput.value > 1) qtyInput.value = +qtyInput.value - 1;
    });
    document.getElementById('pdp-qty-plus')?.addEventListener('click', () => {
      if (qtyInput) qtyInput.value = +qtyInput.value + 1;
    });

    /* ── Variantes ── */
    const PIX_PCT  = {{ section.settings.pix_discount | default: 5 }};
    const INST_CNT = {{ section.settings.installments_count | default: 3 }};
    const SHOW_PIX  = {{ section.settings.show_pix | json }};
    const SHOW_INST = {{ section.settings.show_installments | json }};

    function fmtMoney(cents) {
      if (typeof Shopify !== 'undefined' && Shopify.formatMoney)
        return Shopify.formatMoney(cents, '{{ shop.money_format }}');
      return 'R$ ' + (cents / 100).toFixed(2).replace('.', ',');
    }

    function updateVariant() {
      const opts = [];
      document.querySelectorAll('[data-option-index]').forEach(g => {
        const a = g.querySelector('.pdp__swatch--active, .pdp__size-btn--active');
        if (a) opts.push(a.dataset.value);
      });
      const variants = JSON.parse(document.getElementById('pdp-variants-json')?.textContent || '[]');
      const v = variants.find(vv => opts.every((o, i) => vv.options[i] === o));
      if (!v) return;

      document.getElementById('pdp-variant-id').value = v.id;

      const priceEl = document.getElementById('pdp-price');
      if (priceEl) priceEl.textContent = v.available ? fmtMoney(v.price) : 'Esgotado';

      if (SHOW_PIX) {
        const pixEl = document.getElementById('pdp-price-pix');
        if (pixEl) pixEl.textContent = fmtMoney(Math.round(v.price * (1 - PIX_PCT / 100)));
      }

      if (SHOW_INST && INST_CNT > 1) {
        const instEl = document.getElementById('pdp-inst-value');
        if (instEl) instEl.textContent = fmtMoney(Math.ceil(v.price / INST_CNT));
      }

      const addBtn = document.getElementById('pdp-add-btn');
      if (addBtn) addBtn.disabled = !v.available;

      updateCashback(v.price);
    }

    document.querySelectorAll('[data-option-index]').forEach(group => {
      const btns = group.querySelectorAll('.pdp__swatch, .pdp__size-btn');
      btns.forEach(btn => btn.addEventListener('click', () => {
        btns.forEach(b => b.classList.remove('pdp__swatch--active', 'pdp__size-btn--active'));
        btn.classList.add(btn.classList.contains('pdp__swatch') ? 'pdp__swatch--active' : 'pdp__size-btn--active');
        const valEl = document.getElementById(`pdp-opt-val-${+group.dataset.optionIndex + 1}`);
        if (valEl) valEl.textContent = btn.dataset.value;
        updateVariant();
      }));
    });

    /* ── Cashback ── */
    function updateCashback(priceCents) {
      const wrap = document.getElementById('pdp-cashback-wrap');
      if (!wrap) return;
      const el  = wrap.querySelector('[data-cashback]');
      if (!el) return;
      const pct   = parseFloat(el.dataset.pct) || 8;
      const min   = parseFloat(el.dataset.min) || 10;
      const cb    = (priceCents / 100) * (pct / 100);
      const cifra = el.querySelector('.ame-cashback__cifra');
      const val   = el.querySelector('[data-cashback-value]');
      if (!val) return;
      if (cb >= min) {
        if (cifra) cifra.style.display = '';
        val.textContent = cb.toFixed(2).replace('.', ',');
      } else {
        if (cifra) cifra.style.display = 'none';
        val.textContent = Math.round(pct) + '%';
      }
    }

    /* ── Wishlist ── */
    const wishBtn = document.getElementById('pdp-wishlist');
    wishBtn?.addEventListener('click', () => {
      const on = wishBtn.classList.toggle('is-active');
      wishBtn.querySelector('.material-symbols-outlined').style.fontVariationSettings = on ? "'FILL' 1" : "'FILL' 0";
    });

    /* ── Add to cart AJAX ── */
    document.getElementById('pdp-form')?.addEventListener('submit', async e => {
      e.preventDefault();
      const btn  = document.getElementById('pdp-add-btn');
      const orig = btn.innerHTML;

      btn.innerHTML = '<span class="material-symbols-outlined" style="font-size:1rem;animation:pdp-spin 0.6s linear infinite;">refresh</span>';
      btn.disabled  = true;

      try {
        const res = await fetch('/cart/add.js', {
          method:  'POST',
          headers: { 'X-Requested-With': 'XMLHttpRequest' },
          body:    new FormData(e.target),
        });

        if (!res.ok) throw new Error('cart/add failed');

        /* Busca contagem atualizada */
        const cartRes  = await fetch('/cart.js');
        const cartData = await cartRes.json();
        const count    = cartData.item_count;

        /* Atualiza badge do header */
        const badge = document.querySelector('[data-cart-count]');
        if (badge) {
          badge.textContent = count;
          badge.hidden = count === 0;
        }

        /* Animação no ícone do carrinho */
        const cartBtn = document.querySelector('[data-cart-open]');
        if (cartBtn) {
          cartBtn.classList.remove('cart-bump');
          void cartBtn.offsetWidth; /* reflow para reiniciar a animação se já estiver ativa */
          cartBtn.classList.add('cart-bump');
          cartBtn.addEventListener('animationend', () => cartBtn.classList.remove('cart-bump'), { once: true });
        }

        /* Anima o badge separadamente */
        if (badge) {
          badge.classList.remove('cart-bump');
          void badge.offsetWidth;
          badge.classList.add('cart-bump');
          badge.addEventListener('animationend', () => badge.classList.remove('cart-bump'), { once: true });
        }

        /* Feedback no botão */
        btn.innerHTML = 'Adicionado ✓';
        setTimeout(() => { btn.innerHTML = orig; btn.disabled = false; }, 1800);

      } catch {
        btn.innerHTML = 'Tente novamente';
        btn.style.opacity = '0.7';
        setTimeout(() => { btn.innerHTML = orig; btn.disabled = false; btn.style.opacity = ''; }, 2000);
      }
    });

    /* ── Acordeões ── */
    document.querySelectorAll('.ame-accordion__btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const open = btn.getAttribute('aria-expanded') === 'true';
        document.querySelectorAll('.ame-accordion__btn').forEach(b => {
          b.setAttribute('aria-expanded', 'false');
          b.nextElementSibling.setAttribute('hidden', '');
          b.nextElementSibling.style.maxHeight = '0';
        });
        if (!open) {
          btn.setAttribute('aria-expanded', 'true');
          btn.nextElementSibling.removeAttribute('hidden');
          btn.nextElementSibling.style.maxHeight = '600px';
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Produto",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_related",
      "label": "Exibir produtos relacionados",
      "default": true
    },
    {
      "type": "header",
      "content": "Preço & Pagamento"
    },
    {
      "type": "checkbox",
      "id": "show_pix",
      "label": "Exibir preço no Pix",
      "default": true
    },
    {
      "type": "range",
      "id": "pix_discount",
      "min": 1,
      "max": 20,
      "step": 1,
      "unit": "%",
      "label": "Desconto Pix",
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "show_installments",
      "label": "Exibir parcelamento",
      "default": true
    },
    {
      "type": "range",
      "id": "installments_count",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Número de parcelas sem juros",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_installments_link",
      "label": "Mostrar link 'Ver mais detalhes' no parcelamento",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Acordeão de detalhes",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Materiais & Craft"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Conteúdo",
