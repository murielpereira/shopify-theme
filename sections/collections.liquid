{% comment %} Âme — Lista de coleções (template /collections) {% endcomment %}

<section class="ame-collist">
  <header class="ame-collist__header ame-reveal">
    {%- if section.settings.eyebrow != blank -%}
      <p class="ame-label-sm">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h1 class="ame-collist__title">{{ section.settings.title }}</h1>
    {%- endif -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="ame-collist__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
  </header>

  {%- assign cols_desktop = section.settings.cols_desktop | default: 3 -%}
  {%- assign grid_gap = section.settings.grid_gap | default: 24 -%}

  <div
    class="ame-collist__grid"
    style="--grid-cols: {{ cols_desktop }}; --grid-gap: {{ grid_gap }}px;"
  >
    {%- for collection in collections -%}
      {%- if section.settings.hide_empty and collection.products_count == 0 -%}
        {%- continue -%}
      {%- endif -%}

      <a
        class="ame-collist__card ame-reveal"
        href="{{ collection.url }}"
        aria-label="{{ collection.title }}"
      >
        <div class="ame-collist__card-img-wrap">
          {%- if collection.image != blank -%}
            {{
              collection.image
              | image_url: width: 900
              | image_tag: widths: '300, 600, 900',
                loading: 'lazy',
                class: 'ame-collist__card-img',
                alt: collection.title | escape
            }}
          {%- elsif collection.products.first.featured_image != blank -%}
            {{
              collection.products.first.featured_image
              | image_url: width: 900
              | image_tag: widths: '300, 600, 900',
                loading: 'lazy',
                class: 'ame-collist__card-img',
                alt: collection.title | escape
            }}
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'ame-collist__card-img ame-collist__card-img--placeholder' }}
          {%- endif -%}
          <div class="ame-collist__card-overlay"></div>
        </div>

        <div class="ame-collist__card-caption">
          <h3 class="ame-collist__card-name">{{ collection.title }}</h3>
          {%- if section.settings.show_count -%}
            <p class="ame-collist__card-count">
              {{ collection.products_count }}
              {% if collection.products_count == 1 %}produto{% else %}produtos{% endif %}
            </p>
          {%- endif -%}
          <span class="ame-collist__card-cta">
            Explorar
            <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
          </span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

<style>
  .ame-collist {
    padding: var(--section-gap, 7.5rem) var(--page-margin, 2rem);
    max-width: var(--page-width, 120rem);
    margin: 0 auto;
  }

  .ame-collist__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .ame-collist__title {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1;
    color: var(--color-on-background, #201b14);
    margin: 0;
  }

  .ame-collist__subtitle {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.9375rem;
    color: var(--color-on-surface-variant, #4f4442);
    line-height: 1.6;
    max-width: 36rem;
    margin: 1rem auto 0;
  }

  .ame-collist__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--grid-gap, 24px);
  }
  @media (min-width: 480px) {
    .ame-collist__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 768px) {
    .ame-collist__grid {
      grid-template-columns: repeat(var(--grid-cols, 3), 1fr);
    }
  }

  .ame-collist__card {
    position: relative;
    display: block;
    text-decoration: none;
    border-radius: var(--radius-lg, 0.5rem);
    overflow: hidden;
    background: var(--color-surface-container, #f8ece0);
    transition: transform 0.5s var(--ease-luxury, cubic-bezier(0.22, 1, 0.36, 1));
  }
  .ame-collist__card:hover {
    transform: translateY(-6px);
  }

  .ame-collist__card-img-wrap {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }

  .ame-collist__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    mix-blend-mode: multiply;
    opacity: 0.9;
    transition: transform 1.1s var(--ease-luxury, cubic-bezier(0.22, 1, 0.36, 1));
  }
  .ame-collist__card-img--placeholder { opacity: 0.3; }
  .ame-collist__card:hover .ame-collist__card-img { transform: scale(1.05); }

  .ame-collist__card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(32, 27, 20, 0.55) 0%, rgba(32, 27, 20, 0.15) 50%, transparent 100%);
    pointer-events: none;
  }

  .ame-collist__card-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem 1.75rem 1.75rem;
    color: #fff;
    z-index: 1;
  }

  .ame-collist__card-name {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: clamp(1.125rem, 1.6vw, 1.5rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.15;
    margin: 0 0 0.375rem;
    color: #fff;
  }

  .ame-collist__card-count {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    margin: 0 0 0.875rem;
  }

  .ame-collist__card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.625rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #fff;
    border-bottom: 1px solid rgba(255, 255, 255, 0.4);
    padding-bottom: 0.2rem;
    transition: border-color 0.2s ease, transform 0.3s ease;
  }
  .ame-collist__card-cta .material-symbols-outlined {
    font-size: 0.875rem !important;
    transition: transform 0.3s ease;
  }
  .ame-collist__card:hover .ame-collist__card-cta {
    border-color: #fff;
  }
  .ame-collist__card:hover .ame-collist__card-cta .material-symbols-outlined {
    transform: translateX(3px);
  }

  .ame-label-sm {
    font-family: var(--font-primary--family, 'Lexend', sans-serif);
    font-size: 0.625rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(90, 71, 66, 0.5);
    display: block;
    margin-bottom: 0.75rem;
  }
</style>

{% schema %}
{
  "name": "Lista de coleções",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto acima do título",
      "default": "Categorias"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Coleções"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo (opcional)"
    },
    {
      "type": "header",
      "content": "Grade"
    },
    {
      "type": "range",
      "id": "cols_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "Colunas (desktop)",
      "default": 3
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Espaço entre cards",
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "Mostrar contagem de produtos no card",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_empty",
      "label": "Esconder coleções sem produtos",
      "default": true
    }
  ],
  "presets": [{ "name": "Lista de coleções" }]
}
{% endschema %}
